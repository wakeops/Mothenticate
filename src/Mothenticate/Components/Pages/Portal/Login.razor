@page "/login"
@layout AuthLayout
@inject IAppSettingsService AppSettingsService
@inject IStringLocalizer<SharedResource> L

<PageTitle>Sign In — Mothenticate</PageTitle>

@if (_error is not null)
{
    <MudAlert Severity="Severity.Error" Class="mb-4" Dense="true">@_error</MudAlert>
}

<form method="post" action="/account/login">
    <input type="hidden" name="returnUrl" value="@_returnUrl" />

    <div class="mb-4">
        <label class="mud-typography mud-typography-body2 mb-1 d-block">
            @(_useEmailAsUsername ? L["Login_EmailLabel"] : _allowEmailLogin ? L["Login_UsernameOrEmailLabel"] : L["Login_UsernameLabel"])
        </label>
        <input name="username" type="text" autocomplete="username" required class="auth-input" />
    </div>

    <div class="mb-4">
        <label class="mud-typography mud-typography-body2 mb-1 d-block">@L["Login_PasswordLabel"]</label>
        <input name="password" type="password" autocomplete="current-password" required class="auth-input" />
    </div>

    <div class="d-flex align-center mb-4">
        <input type="checkbox" id="rememberMe" name="rememberMe" value="true" class="auth-checkbox" />
        <label for="rememberMe" class="mud-typography mud-typography-body2 cursor-pointer">
            @L["Login_RememberMe"]
        </label>
    </div>

    <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary"
               FullWidth="true" Size="Size.Large" Class="mb-4">
        @L["Login_SignIn"]
    </MudButton>
</form>

@if (_googleEnabled || _githubEnabled)
{
    <MudDivider Class="mb-4" />
    <MudStack Spacing="2">
        @if (_googleEnabled)
        {
            <MudButton Variant="Variant.Outlined" FullWidth="true" StartIcon="@Icons.Custom.Brands.Google"
                       Href="/connect/external/google">
                @L["Login_ContinueWithGoogle"]
            </MudButton>
        }
        @if (_githubEnabled)
        {
            <MudButton Variant="Variant.Outlined" FullWidth="true" StartIcon="@Icons.Custom.Brands.GitHub"
                       Href="/connect/external/github">
                @L["Login_ContinueWithGitHub"]
            </MudButton>
        }
    </MudStack>
}

@if (_registrationEnabled)
{
    <MudDivider Class="my-4" />
    <MudText Typo="Typo.body2" Align="Align.Center">
        @L["Login_NoAccount"] <MudLink Href="/register">@L["Login_Register"]</MudLink>
    </MudText>
}

@code {
    [SupplyParameterFromQuery] private string? ReturnUrl { get; set; }
    [SupplyParameterFromQuery] private string? Error { get; set; }

    private string? _returnUrl;
    private string? _error;
    private bool _useEmailAsUsername;
    private bool _allowEmailLogin;
    private bool _registrationEnabled;
    private bool _googleEnabled;
    private bool _githubEnabled;

    protected override async Task OnInitializedAsync()
    {
        _returnUrl = ReturnUrl;
        _error = Error switch
        {
            AuthErrorCodes.InvalidCredentials      => L["Error_InvalidCredentials"],
            AuthErrorCodes.AccountLocked           => L["Error_AccountLocked"],
            AuthErrorCodes.AccountInactive         => L["Error_AccountInactive"],
            AuthErrorCodes.SessionExpired          => L["Error_SessionExpired"],
            AuthErrorCodes.AccountDisabled         => L["Error_AccountDisabled"],
            AuthErrorCodes.RegistrationDisabledSso => L["Error_RegistrationDisabledSso"],
            AuthErrorCodes.SsoFailed               => L["Error_SsoFailed"],
            _ => Error
        };

        var settings = await AppSettingsService.GetAsync();
        _useEmailAsUsername  = settings.UseEmailAsUsername;
        _allowEmailLogin     = settings.AllowEmailLogin;
        _registrationEnabled = settings.RegistrationEnabled;
        _googleEnabled       = settings.GoogleSsoEnabled;
        _githubEnabled       = settings.GitHubSsoEnabled;
    }
}
