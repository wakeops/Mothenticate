@page "/portal/profile"
@layout UserLayout
@attribute [Authorize]
@inject IUserService UserService
@inject IUserAttributeService UserAttributeService
@inject ISessionService SessionService
@inject IConsentService ConsentService
@inject IIdentityProviderService IdentityProviderService
@inject ITwoFactorService TwoFactorService
@inject ISsoService SsoService
@inject AuthenticationStateProvider AuthState
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@inject IStringLocalizer<SharedResource> L

<PageTitle>Profile — Mothenticate</PageTitle>

<MudText Typo="Typo.h4" Class="mb-6">@L["Profile_Title"]</MudText>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" />
}
else
{
    <MudTabs Elevation="2" Rounded="true" ApplyEffectsToContainer="true" TabPanelsClass="pa-6">

        <!-- Profile tab -->
        <MudTabPanel Text="@L["Profile_Tab_Profile"]" Icon="@Icons.Material.Filled.Person">
            <MudGrid>
                <MudItem xs="12" md="8">
                    <MudStack Spacing="3">
                        @foreach (var userAttr in _editableAttributes)
                        {
                            <UserAttributeEditor Attribute="userAttr" Values="GetValuesList(userAttr.Id)"
                                                  ReadOnly="@(!userAttr.CanEditUser)" />
                        }

                        <div>
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveProfile"
                                       Disabled="@_savingProfile">
                                @(_savingProfile ? L["Profile_Saving"] : L["Profile_SaveChanges"])
                            </MudButton>
                        </div>
                    </MudStack>
                </MudItem>

            </MudGrid>
        </MudTabPanel>

        <!-- Security tab -->
        <MudTabPanel Text="@L["Profile_Tab_Security"]" Icon="@Icons.Material.Filled.Security">
            <MudGrid>
                <MudItem xs="12" md="6">
                    <!-- Change password -->
                    <MudPaper Elevation="1" Class="pa-4 mb-4">
                        <MudText Typo="Typo.h6" GutterBottom="true">@L["Profile_ChangePassword"]</MudText>
                        <MudStack Spacing="3">
                            <MudTextField @bind-Value="_currentPassword" T="string" Label="@L["Profile_CurrentPassword"]"
                                          InputType="InputType.Password" Variant="Variant.Outlined" />
                            <MudTextField @bind-Value="_newPassword" T="string" Label="@L["Profile_NewPassword"]"
                                          InputType="InputType.Password" Variant="Variant.Outlined" />
                            <MudTextField @bind-Value="_confirmPassword" T="string" Label="@L["Profile_ConfirmNewPassword"]"
                                          InputType="InputType.Password" Variant="Variant.Outlined" />
                            <div>
                                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="ChangePassword"
                                           Disabled="@_savingPassword">
                                    @(_savingPassword ? L["Profile_Updating"] : L["Profile_UpdatePassword"])
                                </MudButton>
                            </div>
                        </MudStack>
                    </MudPaper>

                    <!-- Two-factor authentication -->
                    <MudPaper Elevation="1" Class="pa-4 mb-4">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-3">
                            <MudText Typo="Typo.h6">@L["Profile_AuthenticatorApp"]</MudText>
                            <MudSpacer />
                            @if (_twoFactorEnabled)
                            {
                                <MudChip T="string" Color="Color.Success" Size="Size.Small">@L["Profile_Enabled"]</MudChip>
                            }
                            else
                            {
                                <MudChip T="string" Color="Color.Default" Size="Size.Small">@L["Profile_Disabled"]</MudChip>
                            }
                        </MudStack>

                        @if (_twoFactorEnabled)
                        {
                            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3">
                                @L["Profile_TwoFactorActive", _recoveryCodeCount]
                            </MudText>
                            <MudStack Row="true" Spacing="2" Wrap="Wrap.Wrap">
                                <MudButton Variant="Variant.Outlined" Size="Size.Small"
                                           OnClick='() => Navigation.NavigateTo("/portal/2fa-setup")'>
                                    @L["Profile_ResetAuthenticator"]
                                </MudButton>
                                <MudButton Variant="Variant.Outlined" Color="Color.Error" Size="Size.Small"
                                           OnClick="DisableTwoFactor">
                                    @L["Profile_Disable2FA"]
                                </MudButton>
                            </MudStack>
                        }
                        else
                        {
                            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3">
                                @L["Profile_TwoFactorInactive"]
                            </MudText>
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                                       OnClick='() => Navigation.NavigateTo("/portal/2fa-setup")'>
                                @L["Profile_SetUpAuthenticator"]
                            </MudButton>
                        }
                    </MudPaper>
                </MudItem>

                <MudItem xs="12" md="6">
                    <!-- Linked accounts -->
                    <MudPaper Elevation="1" Class="pa-4">
                        <MudText Typo="Typo.h6" GutterBottom="true">@L["Profile_LinkedAccounts"]</MudText>
                        @if (_ssoProviders.Count == 0)
                        {
                            <MudText Typo="Typo.body2" Color="Color.Secondary">
                                @L["Profile_NoProviders"]
                            </MudText>
                        }
                        else
                        {
                            @foreach (var provider in _ssoProviders)
                            {
                                var linked = _linkedLogins.FirstOrDefault(l => l.LoginProvider == provider.Alias);
                                var showRow = provider.ShowInAccountConsole == Mothenticate.Data.Entities.ShowInAccountConsole.Always || linked is not null;
                                @if (showRow)
                                {
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-3">
                                        <MudIcon Icon="@GetProviderIcon(provider.ProviderType.Name)" />
                                        <MudText Class="flex-1">@provider.DisplayName</MudText>
                                        @if (linked is not null)
                                        {
                                            <MudChip T="string" Color="Color.Success" Size="Size.Small" Class="mr-2">@L["Profile_Linked"]</MudChip>
                                            <MudButton Size="Size.Small" Color="Color.Error" Variant="Variant.Outlined"
                                                       OnClick="() => UnlinkProvider(provider.Alias, linked.ProviderKey)">
                                                @L["Profile_Unlink"]
                                            </MudButton>
                                        }
                                        else
                                        {
                                            <MudButton Size="Size.Small" Variant="Variant.Outlined"
                                                       Href="@("/connect/external/" + provider.Alias + "?linkUserId=" + _userId)">
                                                @L["Profile_Link"]
                                            </MudButton>
                                        }
                                    </MudStack>
                                }
                            }
                        }
                    </MudPaper>
                </MudItem>
            </MudGrid>
        </MudTabPanel>

        <!-- Sessions tab -->
        <MudTabPanel Text="@L["Profile_Tab_Sessions"]" Icon="@Icons.Material.Filled.Devices">
            <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4">
                <MudText Typo="Typo.h6">@L["Profile_ActiveSessions"]</MudText>
                <MudSpacer />
                <MudButton Variant="Variant.Outlined" Color="Color.Error"
                           StartIcon="@Icons.Material.Filled.Logout"
                           OnClick="RevokeAllSessions">
                    @L["Profile_SignOutAll"]
                </MudButton>
            </MudStack>

            @if (_sessions.Count == 0)
            {
                <MudAlert Severity="Severity.Info">@L["Profile_NoSessions"]</MudAlert>
            }
            else
            {
                <MudStack Spacing="2">
                    @foreach (var session in _sessions)
                    {
                        <MudPaper Outlined="true" Class="pa-3">
                            <MudStack Row="true" AlignItems="AlignItems.Center">
                                <MudIcon Icon="@Icons.Material.Filled.Computer" Color="Color.Secondary" />
                                <MudStack Spacing="0" Class="flex-1">
                                    <MudText Typo="Typo.body2">@(session.UserAgent ?? L["Profile_UnknownDevice"])</MudText>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                                        @session.IpAddress — Last active @session.LastActiveAt.ToString("MMM dd, yyyy HH:mm")
                                    </MudText>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                                        Started @session.CreatedAt.ToString("MMM dd, yyyy HH:mm")
                                    </MudText>
                                </MudStack>
                                <MudIconButton Icon="@Icons.Material.Filled.Logout" Color="Color.Error"
                                               Size="Size.Small"
                                               OnClick="() => RevokeSession(session.Id)" />
                            </MudStack>
                        </MudPaper>
                    }
                </MudStack>
            }
        </MudTabPanel>

        <!-- Consents tab -->
        <MudTabPanel Text="@L["Profile_Tab_Consents"]" Icon="@Icons.Material.Filled.VerifiedUser">
            <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4">
                <MudText Typo="Typo.h6">@L["Profile_AuthorizedApps"]</MudText>
                <MudSpacer />
                @if (_consents.Count > 0)
                {
                    <MudButton Variant="Variant.Outlined" Color="Color.Error"
                               StartIcon="@Icons.Material.Filled.DeleteSweep"
                               OnClick="RevokeAllConsents">
                        @L["Profile_RevokeAll"]
                    </MudButton>
                }
            </MudStack>

            @if (_consents.Count == 0)
            {
                <MudAlert Severity="Severity.Info">@L["Profile_NoConsents"]</MudAlert>
            }
            else
            {
                <MudStack Spacing="2">
                    @foreach (var consent in _consents)
                    {
                        <MudPaper Outlined="true" Class="pa-3">
                            <MudStack Row="true" AlignItems="AlignItems.Center">
                                <MudAvatar Color="Color.Primary" Size="Size.Small">
                                    @(consent.ApplicationName?.Length > 0 ? consent.ApplicationName[0].ToString().ToUpper() : "?")
                                </MudAvatar>
                                <MudStack Spacing="0" Class="flex-1 ml-2">
                                    <MudText Typo="Typo.body2">@(consent.ApplicationName ?? L["Profile_UnknownApp"])</MudText>
                                    <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1" Class="mt-1">
                                        @foreach (var scope in consent.Scopes)
                                        {
                                            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">@scope</MudChip>
                                        }
                                    </MudStack>
                                    @if (consent.CreationDate.HasValue)
                                    {
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                                            @L["Profile_AuthorizedOn", consent.CreationDate.Value.ToString("MMM dd, yyyy")]
                                        </MudText>
                                    }
                                </MudStack>
                                <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error"
                                               Size="Size.Small"
                                               OnClick="() => RevokeConsent(consent.Id!)" />
                            </MudStack>
                        </MudPaper>
                    }
                </MudStack>
            }
        </MudTabPanel>

    </MudTabs>
}

@code {
    private ApplicationUser? _user;
    private string _userId = string.Empty;
    private bool _loading = true;

    // Profile
    private static readonly string[] IdentifierAttributeNames = ["username", "email"];

    private List<UserAttribute> _editableAttributes = [];
    private Dictionary<int, List<string?>> _attributeValues = [];
    private bool _savingProfile;

    // Security
    private string _currentPassword = string.Empty;
    private string _newPassword = string.Empty;
    private string _confirmPassword = string.Empty;
    private bool _savingPassword;

    // 2FA
    private bool _twoFactorEnabled;
    private int _recoveryCodeCount;

    // SSO
    private List<Microsoft.AspNetCore.Identity.UserLoginInfo> _linkedLogins = [];
    private List<Mothenticate.Data.Entities.IdentityProvider> _ssoProviders = [];

    // Sessions
    private List<UserSession> _sessions = [];

    // Consents
    private List<ConsentInfo> _consents = [];

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthState.GetAuthenticationStateAsync();
        _userId = state.User.GetUserId() ?? string.Empty;

        if (string.IsNullOrEmpty(_userId))
        {
            _loading = false;
            return;
        }

        _user = await UserService.GetByIdAsync(_userId);

        var allAttributes = await UserAttributeService.GetAllDefinitionsAsync();
        _editableAttributes = allAttributes.Where(a => a.CanViewUser).ToList();

        var values = await UserAttributeService.GetUserValuesAsync(_userId);
        _attributeValues = values
            .GroupBy(v => v.UserAttributeId)
            .ToDictionary(g => g.Key, g => g.OrderBy(v => v.Ordinal).Select(v => v.Value).ToList());

        if (_user is not null)
        {
            SeedIdentifierValue("username", _user.UserName);
            SeedIdentifierValue("email", _user.Email);
        }

        _sessions = [.. await SessionService.GetActiveByUserIdAsync(_userId)];
        _consents = [.. await ConsentService.GetBySubjectAsync(_userId)];

        _twoFactorEnabled = await TwoFactorService.IsEnabledAsync(_userId);
        if (_twoFactorEnabled)
            _recoveryCodeCount = await TwoFactorService.CountRecoveryCodesAsync(_userId);

        _linkedLogins = [.. await SsoService.GetLoginsAsync(_userId)];

        var allProviders = await IdentityProviderService.GetProvidersAsync();
        _ssoProviders = allProviders
            .Where(p => p.IsEnabled && p.ShowInAccountConsole != Mothenticate.Data.Entities.ShowInAccountConsole.Never)
            .ToList();

        _loading = false;
    }

    private List<string?> GetValuesList(int attributeId)
    {
        if (!_attributeValues.TryGetValue(attributeId, out var list))
        {
            list = [];
            _attributeValues[attributeId] = list;
        }

        return list;
    }

    private static bool IsIdentifierAttribute(UserAttribute attribute)
        => IdentifierAttributeNames.Contains(attribute.Name, StringComparer.OrdinalIgnoreCase);

    private UserAttribute? FindAttribute(string name)
        => _editableAttributes.FirstOrDefault(a => a.Name.Equals(name, StringComparison.OrdinalIgnoreCase));

    private void SeedIdentifierValue(string name, string? value)
    {
        var attribute = FindAttribute(name);
        if (attribute is not null)
        {
            _attributeValues[attribute.Id] = [value];
        }
    }

    private string? GetIdentifierValue(string name)
    {
        var attribute = FindAttribute(name);
        if (attribute is null)
        {
            return null;
        }

        var values = GetValuesList(attribute.Id);
        return values.Count > 0 ? values[0] : null;
    }

    private async Task SaveProfile()
    {
        _savingProfile = true;
        try
        {
            var userName = GetIdentifierValue("username") ?? _user?.UserName ?? string.Empty;
            var email = GetIdentifierValue("email") ?? _user?.Email ?? string.Empty;

            var result = await UserService.UpdateIdentifiersAsync(_userId, userName, email);
            if (result.Succeeded)
            {
                foreach (var attribute in _editableAttributes)
                {
                    if (IsIdentifierAttribute(attribute)) continue;
                    await UserAttributeService.SetUserValuesAsync(_userId, attribute.Id, GetValuesList(attribute.Id));
                }
                Snackbar.Add(L["Profile_Saved"], Severity.Success);
            }
            else
            {
                Snackbar.Add(result.Errors.FirstOrDefault()?.Description ?? L["Profile_SaveFailed"], Severity.Error);
            }
        }
        finally
        {
            _savingProfile = false;
        }
    }

    private async Task ChangePassword()
    {
        if (_newPassword != _confirmPassword)
        {
            Snackbar.Add(L["Profile_PasswordMismatch"], Severity.Warning);
            return;
        }
        _savingPassword = true;
        try
        {
            var result = await UserService.ChangePasswordAsync(_userId, _currentPassword, _newPassword);
            if (result.Succeeded)
            {
                _currentPassword = _newPassword = _confirmPassword = string.Empty;
                Snackbar.Add(L["Profile_PasswordUpdated"], Severity.Success);
            }
            else
            {
                Snackbar.Add(result.Errors.FirstOrDefault()?.Description ?? L["Profile_SaveFailed"], Severity.Error);
            }
        }
        finally
        {
            _savingPassword = false;
        }
    }

    private async Task RevokeSession(Guid sessionId)
    {
        await SessionService.RevokeAsync(sessionId);
        _sessions = [.. await SessionService.GetActiveByUserIdAsync(_userId)];
        Snackbar.Add(L["Profile_SessionRevoked"], Severity.Success);
    }

    private async Task RevokeAllSessions()
    {
        await SessionService.RevokeAllForUserAsync(_userId);
        _sessions = [];
        Snackbar.Add(L["Profile_AllSessionsRevoked"], Severity.Info);
    }

    private async Task RevokeConsent(string authId)
    {
        await ConsentService.RevokeAsync(authId);
        _consents = [.. await ConsentService.GetBySubjectAsync(_userId)];
        Snackbar.Add(L["Profile_AccessRevoked"], Severity.Success);
    }

    private async Task RevokeAllConsents()
    {
        await ConsentService.RevokeAllBySubjectAsync(_userId);
        _consents = [];
        Snackbar.Add(L["Profile_AllAccessRevoked"], Severity.Success);
    }

    private async Task DisableTwoFactor()
    {
        await TwoFactorService.DisableAsync(_userId);
        _twoFactorEnabled = false;
        _recoveryCodeCount = 0;
        Snackbar.Add(L["Profile_2FADisabled"], Severity.Success);
    }

    private static string GetProviderIcon(string typeName) => typeName.ToLowerInvariant() switch
    {
        "google" => Icons.Custom.Brands.Google,
        "github" => Icons.Custom.Brands.GitHub,
        _        => Icons.Material.Filled.Login,
    };

    private async Task UnlinkProvider(string provider, string providerKey)
    {
        var result = await SsoService.UnlinkLoginAsync(_userId, provider, providerKey);
        if (result.Succeeded)
        {
            _linkedLogins = [.. await SsoService.GetLoginsAsync(_userId)];
            Snackbar.Add(L["Profile_ProviderUnlinked", provider], Severity.Success);
        }
        else
        {
            Snackbar.Add(result.Errors.FirstOrDefault()?.Description ?? L["Profile_UnlinkFailed"], Severity.Error);
        }
    }
}
