@page "/setup"
@layout AuthLayout
@inject ISeedService SeedService
@inject NavigationManager Navigation
@inject IStringLocalizer<SharedResource> L

<PageTitle>Setup — Mothenticate</PageTitle>

<MudText Typo="Typo.h5" Class="mb-1">@L["Setup_Welcome"]</MudText>
<MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-6">
    @L["Setup_Subtitle"]
</MudText>

@if (_error is not null)
{
    <MudAlert Severity="Severity.Error" Class="mb-4" Dense="true">@_error</MudAlert>
}

<form method="post" action="/account/setup">
    <div class="mb-3">
        <label class="mud-typography mud-typography-body2 mb-1 d-block">@L["Setup_UsernameLbl"]</label>
        <input name="username" type="text" autocomplete="username" required class="auth-input" />
    </div>

    <div class="mb-3">
        <label class="mud-typography mud-typography-body2 mb-1 d-block">@L["Setup_EmailLbl"]</label>
        <input name="email" type="email" autocomplete="email" required class="auth-input" />
    </div>

    <div class="mb-4">
        <label class="mud-typography mud-typography-body2 mb-1 d-block">@L["Setup_PasswordLbl"]</label>
        <input name="password" type="password" autocomplete="new-password" required class="auth-input"
               @oninput="OnPasswordInput" />
        <div class="password-rules mt-2">
            <PasswordRule Met="_hasMinLength" Label="@L["Setup_PasswordRule_MinLength"]" />
            <PasswordRule Met="_hasUpper"     Label="@L["Setup_PasswordRule_Upper"]" />
            <PasswordRule Met="_hasLower"     Label="@L["Setup_PasswordRule_Lower"]" />
            <PasswordRule Met="_hasDigit"     Label="@L["Setup_PasswordRule_Digit"]" />
            <PasswordRule Met="_hasSpecial"   Label="@L["Setup_PasswordRule_Special"]" />
        </div>
    </div>

    <div class="mb-4">
        <label class="mud-typography mud-typography-body2 mb-1 d-block">@L["Setup_ConfirmPassword"]</label>
        <input name="confirm_password" type="password" autocomplete="new-password" required class="auth-input"
               @oninput="OnConfirmInput" />
        @if (_confirm.Length > 0 && !_passwordsMatch)
        {
            <MudText Typo="Typo.caption" Color="Color.Error" Class="mt-1">@L["Setup_PasswordsDoNotMatch"]</MudText>
        }
    </div>

    <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary"
               FullWidth="true" Size="Size.Large" Disabled="_submitDisabled">
        @L["Setup_CreateAdmin"]
    </MudButton>
</form>

@code {
    [SupplyParameterFromQuery] private string? Error { get; set; }

    private string? _error;
    private string _password = string.Empty;
    private string _confirm = string.Empty;
    private bool _hasMinLength;
    private bool _hasUpper;
    private bool _hasLower;
    private bool _hasDigit;
    private bool _hasSpecial;

    private bool _passwordsMatch => _confirm.Length == 0 || _password == _confirm;
    private bool _submitDisabled => !(_hasMinLength && _hasUpper && _hasLower && _hasDigit && _hasSpecial && _password == _confirm);

    protected override async Task OnInitializedAsync()
    {
        _error = string.IsNullOrEmpty(Error) ? null : Uri.UnescapeDataString(Error);

        if (!await SeedService.IsFirstRunAsync())
            Navigation.NavigateTo("/login", replace: true);
    }

    private void OnPasswordInput(ChangeEventArgs e)
    {
        _password     = e.Value?.ToString() ?? string.Empty;
        _hasMinLength = _password.Length >= 6;
        _hasUpper     = _password.Any(char.IsUpper);
        _hasLower     = _password.Any(char.IsLower);
        _hasDigit     = _password.Any(char.IsDigit);
        _hasSpecial   = _password.Any(c => !char.IsLetterOrDigit(c));
    }

    private void OnConfirmInput(ChangeEventArgs e)
    {
        _confirm = e.Value?.ToString() ?? string.Empty;
    }
}
