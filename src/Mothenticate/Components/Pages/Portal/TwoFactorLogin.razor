@page "/login/2fa"
@layout AuthLayout

<PageTitle>Two-Factor Authentication — Mothenticate</PageTitle>

@if (_useRecovery)
{
    <MudText Typo="Typo.h6" GutterBottom="true">Enter Recovery Code</MudText>
    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
        Enter one of your recovery codes to sign in.
    </MudText>

    @if (_error is not null)
    {
        <MudAlert Severity="Severity.Error" Class="mb-4" Dense="true">@_error</MudAlert>
    }

    <form method="post" action="/account/verify2fa">
        <input type="hidden" name="isRecoveryCode" value="true" />
        <div class="mb-4">
            <label class="mud-typography mud-typography-body2 mb-1 d-block">Recovery Code</label>
            <input name="code" type="text" autocomplete="off" required
                   class="auth-input font-family-mono" />
        </div>
        <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary"
                   FullWidth="true" Size="Size.Large" Class="mb-3">
            Verify
        </MudButton>
    </form>
    <MudButton Variant="Variant.Text" FullWidth="true" OnClick='() => _useRecovery = false'>
        Use authenticator app instead
    </MudButton>
}
else
{
    <MudText Typo="Typo.h6" GutterBottom="true">Two-Factor Authentication</MudText>
    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
        Open your authenticator app and enter the current code.
    </MudText>

    @if (_error is not null)
    {
        <MudAlert Severity="Severity.Error" Class="mb-4" Dense="true">@_error</MudAlert>
    }

    <form method="post" action="/account/verify2fa">
        <input type="hidden" name="isRecoveryCode" value="false" />
        <div class="mb-4">
            <label class="mud-typography mud-typography-body2 mb-1 d-block">Authenticator Code</label>
            <input name="code" type="text" autocomplete="one-time-code" inputmode="numeric"
                   maxlength="6" required
                   class="auth-input auth-input-code" />
        </div>
        <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary"
                   FullWidth="true" Size="Size.Large" Class="mb-3">
            Verify
        </MudButton>
    </form>
    <MudButton Variant="Variant.Text" FullWidth="true" OnClick='() => _useRecovery = true'>
        Use a recovery code instead
    </MudButton>
}

<MudDivider Class="my-4" />
<MudText Typo="Typo.body2" Align="Align.Center">
    <MudLink Href="/login">Cancel and return to sign in</MudLink>
</MudText>

@code {
    [SupplyParameterFromQuery] private string? Error { get; set; }

    private bool _useRecovery;
    private string? _error;

    protected override void OnInitialized()
    {
        _error = Error switch
        {
            AuthErrorCodes.InvalidCredentials => "Invalid code. Please try again.",
            _                                 => Error
        };
    }
}
