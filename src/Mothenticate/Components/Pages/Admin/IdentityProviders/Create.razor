@page "/admin/identity-providers/create/{ProviderTypeId:int}"
@attribute [Authorize(Policy = AuthDefaults.AppAdminUserPolicy)]
@inject IIdentityProviderService IdentityProviderService
@inject ISsoSettingsChangeNotifier SsoNotifier
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject IStringLocalizer<SharedResource> L

<PageTitle>@L["Admin_IdP_Create_PageTitle"] — Mothenticate Admin</PageTitle>

<MudButton StartIcon="@Icons.Material.Filled.ArrowBack" Variant="Variant.Text" Size="Size.Small"
           OnClick='() => Navigation.NavigateTo("/admin/settings?tab=idp")' Class="mb-4">
    @L["Admin_IdP_ReturnToList"]
</MudButton>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" />
}
else if (_providerType is null)
{
    <MudAlert Severity="Severity.Error">@L["Admin_IdP_ProviderNotFound"]</MudAlert>
}
else
{
    <MudText Typo="Typo.h4" GutterBottom="true">@string.Format(L["Admin_IdP_Create_Title"], _providerType.Name)</MudText>

    <MudPaper Elevation="2" Class="pa-6" MaxWidth="700px">
        <MudForm @ref="_form">
            <MudStack Spacing="3">

                <!-- Redirect URI -->
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                    <MudTextField Value="@RedirectUri" Label="@L["Admin_IdP_RedirectUri"]"
                                  Variant="Variant.Outlined" ReadOnly="true" Class="flex-1" />
                    <MudIconButton Icon="@Icons.Material.Filled.ContentCopy" Size="Size.Medium"
                                   aria-label="@L["Admin_IdP_CopyUri"]" OnClick="CopyRedirectUri" />
                </MudStack>

                <MudTextField @bind-Value="_alias" Label="@L["Admin_IdP_Alias"]"
                              Variant="Variant.Outlined" Required="true"
                              HelperText="@L["Admin_IdP_Alias_Helper"]"
                              Immediate="true" />

                <MudTextField @bind-Value="_displayName" Label="@L["Admin_IdP_DisplayName"]"
                              Variant="Variant.Outlined" Required="true" />

                @if (_showEndpointFields && _providerType.ProtocolType == ProtocolType.OIDC)
                {
                    <MudTextField @bind-Value="_discoveryUrl" Label="@L["Admin_IdP_DiscoveryUrl"]"
                                  Variant="Variant.Outlined" />
                }

                @if (_showEndpointFields)
                {
                    <MudTextField @bind-Value="_authorizationEndpoint" Label="@L["Admin_IdP_AuthorizationEndpoint"]"
                                  Variant="Variant.Outlined" />
                    <MudTextField @bind-Value="_tokenEndpoint" Label="@L["Admin_IdP_TokenEndpoint"]"
                                  Variant="Variant.Outlined" />
                    <MudTextField @bind-Value="_userinfoEndpoint" Label="@L["Admin_IdP_UserinfoEndpoint"]"
                                  Variant="Variant.Outlined" />
                    @if (_providerType.ProtocolType == ProtocolType.OAuth2)
                    {
                        <MudTextField @bind-Value="_defaultScopes" Label="@L["Admin_IdP_DefaultScopes"]"
                                      Variant="Variant.Outlined" />
                    }
                }

                @if (_useCredentialFields)
                {
                    <MudTextField @bind-Value="_clientId" Label="@L["Admin_IdP_ClientId"]"
                                  Variant="Variant.Outlined" Required="true" />
                    <MudTextField @bind-Value="_clientSecret" Label="@L["Admin_IdP_ClientSecret"]"
                                  Variant="Variant.Outlined" Required="true"
                                  InputType="@(_showSecret ? InputType.Text : InputType.Password)"
                                  Adornment="Adornment.End"
                                  AdornmentIcon="@(_showSecret ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                                  OnAdornmentClick="() => _showSecret = !_showSecret" />
                }

                @if (_showEndpointFields)
                {
                    <MudTextField @bind-Value="_idField" Label="@L["Admin_IdP_IdField"]"
                                  Variant="Variant.Outlined" />
                    <MudTextField @bind-Value="_nameField" Label="@L["Admin_IdP_NameField"]"
                                  Variant="Variant.Outlined" />
                    <MudTextField @bind-Value="_emailField" Label="@L["Admin_IdP_EmailField"]"
                                  Variant="Variant.Outlined" />
                }

                <MudNumericField @bind-Value="_displayOrder" Label="@L["Admin_IdP_DisplayOrder"]"
                                 Variant="Variant.Outlined" />

                <MudSelect @bind-Value="_syncMode" Label="@L["Admin_IdP_SyncMode"]"
                           Variant="Variant.Outlined">
                    <MudSelectItem Value="SyncMode.Import">@L["Admin_IdP_SyncMode_Import"]</MudSelectItem>
                    <MudSelectItem Value="SyncMode.Update">@L["Admin_IdP_SyncMode_Update"]</MudSelectItem>
                </MudSelect>

                <MudSelect @bind-Value="_showInAccountConsole" Label="@L["Admin_IdP_ShowInConsole"]"
                           Variant="Variant.Outlined">
                    <MudSelectItem Value="ShowInAccountConsole.Always">@L["Admin_IdP_ShowInConsole_Always"]</MudSelectItem>
                    <MudSelectItem Value="ShowInAccountConsole.WhenLinked">@L["Admin_IdP_ShowInConsole_WhenLinked"]</MudSelectItem>
                    <MudSelectItem Value="ShowInAccountConsole.Never">@L["Admin_IdP_ShowInConsole_Never"]</MudSelectItem>
                </MudSelect>

                <MudStack>
                    <MudSwitch @bind-Value="_accountLinkingOnly" Color="Color.Primary"
                               Label="@L["Admin_IdP_AccountLinkingOnly"]" />
                    <MudSwitch @bind-Value="_hideOnLoginPage" Color="Color.Primary"
                               Label="@L["Admin_IdP_HideOnLoginPage"]" />
                </MudStack>

                <MudStack Row="true" Spacing="2" Class="mt-2">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Add" Disabled="@_saving">
                        @(_saving ? L["Admin_IdP_Adding"] : L["Admin_IdP_Add"])
                    </MudButton>
                    <MudButton Variant="Variant.Text" OnClick='() => Navigation.NavigateTo("/admin/settings?tab=idp")'>
                        @L["Admin_IdP_Cancel"]
                    </MudButton>
                </MudStack>

            </MudStack>
        </MudForm>
    </MudPaper>
}

@code {
    [Parameter] public int ProviderTypeId { get; set; }

    private IdentityProviderType? _providerType;
    private bool _loading = true;
    private bool _saving;
    private MudForm _form = default!;

    private bool _useCredentialFields;
    private bool _showEndpointFields;

    private string _alias = string.Empty;
    private string _displayName = string.Empty;
    private bool _accountLinkingOnly = false;
    private bool _hideOnLoginPage = false;
    private ShowInAccountConsole _showInAccountConsole = ShowInAccountConsole.Always;
    private SyncMode _syncMode = SyncMode.Import;
    private int? _displayOrder;

    private string _clientId = string.Empty;
    private string _clientSecret = string.Empty;
    private bool _showSecret;
    private string _discoveryUrl = string.Empty;
    private string _authorizationEndpoint = string.Empty;
    private string _tokenEndpoint = string.Empty;
    private string _userinfoEndpoint = string.Empty;
    private string _defaultScopes = string.Empty;
    private string _idField = string.Empty;
    private string _nameField = string.Empty;
    private string _emailField = string.Empty;

    private string RedirectUri =>
        Navigation.BaseUri.TrimEnd('/') + "/connect/external/" + _alias + "/finalize";

    protected override async Task OnInitializedAsync()
    {
        var types = await IdentityProviderService.GetProviderTypesAsync();
        _providerType = types.FirstOrDefault(t => t.Id == ProviderTypeId);

        if (_providerType is not null)
        {
            _alias = _providerType.Name.ToLowerInvariant().Replace(" ", "-");
            _useCredentialFields = _providerType.ProtocolType is ProtocolType.OIDC or ProtocolType.OAuth2;
            _showEndpointFields = _useCredentialFields && _providerType.DefaultConfiguration is null;

            if (_showEndpointFields)
            {
                (_idField, _nameField, _emailField) = _providerType.ProtocolType == ProtocolType.OIDC
                    ? ("sub", "name", "email")
                    : ("id", "name", "email");
            }
        }

        _loading = false;
    }

    private async Task Add()
    {
        await _form.ValidateAsync();
        if (!_form.IsValid) return;

        _saving = true;
        try
        {
            var props = BuildProps();
            IdentityProviderConfiguration? config = props.Count > 0
                ? new IdentityProviderConfiguration { Properties = System.Text.Json.JsonSerializer.Serialize(props) }
                : null;

            var provider = new IdentityProvider
            {
                ProviderTypeId       = ProviderTypeId,
                Configuration        = config,
                Alias                = _alias,
                DisplayName          = _displayName,
                IsEnabled            = true,
                AccountLinkingOnly   = _accountLinkingOnly,
                HideOnLoginPage      = _hideOnLoginPage,
                ShowInAccountConsole = _showInAccountConsole,
                SyncMode             = _syncMode,
                DisplayOrder         = _displayOrder,
            };

            await IdentityProviderService.CreateProviderAsync(provider);
            SsoNotifier.NotifyChanged();
            Snackbar.Add(string.Format(L["Admin_IdP_Created"], _alias), Severity.Success);
            Navigation.NavigateTo("/admin/settings?tab=idp");
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
        finally
        {
            _saving = false;
        }
    }

    private Dictionary<string, string> BuildProps()
    {
        var props = new Dictionary<string, string>();
        if (_useCredentialFields)
        {
            props["client_id"] = _clientId;
            props["client_secret"] = _clientSecret;
        }
        if (_showEndpointFields)
        {
            if (!string.IsNullOrWhiteSpace(_discoveryUrl)) props["discovery_url"] = _discoveryUrl;
            if (!string.IsNullOrWhiteSpace(_authorizationEndpoint)) props["authorization_endpoint"] = _authorizationEndpoint;
            if (!string.IsNullOrWhiteSpace(_tokenEndpoint)) props["token_endpoint"] = _tokenEndpoint;
            if (!string.IsNullOrWhiteSpace(_userinfoEndpoint)) props["userinfo_endpoint"] = _userinfoEndpoint;
            if (!string.IsNullOrWhiteSpace(_defaultScopes)) props["default_scopes"] = _defaultScopes;
            if (!string.IsNullOrWhiteSpace(_idField)) props["id_field"] = _idField;
            if (!string.IsNullOrWhiteSpace(_nameField)) props["name_field"] = _nameField;
            if (!string.IsNullOrWhiteSpace(_emailField)) props["email_field"] = _emailField;
        }
        return props;
    }

    private async Task CopyRedirectUri()
    {
        await JS.InvokeVoidAsync("navigator.clipboard.writeText", RedirectUri);
        Snackbar.Add(L["Admin_IdP_UriCopied"], Severity.Info);
    }
}
