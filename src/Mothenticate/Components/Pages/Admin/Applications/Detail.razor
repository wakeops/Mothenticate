@page "/admin/applications/create"
@page "/admin/applications/{Id:int}"
@attribute [Authorize(Policy = AuthDefaults.AppAdminUserPolicy)]
@inject IAppLauncherService ApplicationService
@inject IClientService ClientService
@inject IUserService UserService
@inject IGroupService GroupService
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@inject IStringLocalizer<SharedResource> L

<PageTitle>@(_isCreate ? L["Admin_AppDetail_NewApp"] : _model.Name) — Mothenticate Admin</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4">
    <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" OnClick='() => Navigation.NavigateTo("/admin/applications")' />
    <MudText Typo="Typo.h4">@(_isCreate ? L["Admin_AppDetail_NewApp"] : L["Admin_AppDetail_EditApp"])</MudText>
</MudStack>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" />
}
else
{
    <MudGrid>
        <MudItem xs="12" md="8">
            <MudForm @ref="_form" @bind-IsValid="_valid">

                <!-- Basic Info -->
                <MudPaper Elevation="2" Class="pa-4 mb-4">
                    <MudText Typo="Typo.h6" GutterBottom="true">@L["Admin_AppDetail_BasicInfo"]</MudText>
                    <MudGrid>
                        <MudItem xs="12" sm="6">
                            <MudTextField @bind-Value="_model.Name" Label="@L["Admin_AppDetail_Name"]" Required="true"
                                          RequiredError="@L["Admin_AppDetail_Name_Required"]" Variant="Variant.Outlined" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudTextField @bind-Value="_model.Slug" Label="@L["Admin_AppDetail_Slug"]" Required="true"
                                          RequiredError="@L["Admin_AppDetail_Slug_Required"]" Variant="Variant.Outlined"
                                          HelperText="@L["Admin_AppDetail_Slug_Helper"]" />
                        </MudItem>
                        <MudItem xs="12">
                            <MudTextField @bind-Value="_model.Description" Label="@L["Admin_AppDetail_Description"]" Variant="Variant.Outlined"
                                          Lines="2" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudTextField @bind-Value="_model.IconUrl" Label="@L["Admin_AppDetail_IconUrl"]" Variant="Variant.Outlined"
                                          HelperText="@L["Admin_AppDetail_IconUrl_Helper"]" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudTextField @bind-Value="_model.LaunchUrl" Label="@L["Admin_AppDetail_LaunchUrl"]" Variant="Variant.Outlined"
                                          HelperText="@L["Admin_AppDetail_LaunchUrl_Helper"]" />
                        </MudItem>
                        <MudItem xs="12">
                            <MudSelect @bind-Value="_model.LinkedClientId" Label="@L["Admin_AppDetail_LinkedClient"]"
                                       Variant="Variant.Outlined" Clearable="true"
                                       HelperText="@L["Admin_AppDetail_LinkedClient_Helper"]">
                                @foreach (var client in _clients)
                                {
                                    <MudSelectItem Value="@client.Id">@client.DisplayName (@client.ClientId)</MudSelectItem>
                                }
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudSwitch @bind-Value="_model.IsEnabled" Label="@L["Admin_AppDetail_Enabled"]" Color="Color.Primary" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudSwitch @bind-Value="_model.IsPublic" Label="@L["Admin_AppDetail_Public"]"
                                       Color="Color.Primary" />
                        </MudItem>
                    </MudGrid>
                </MudPaper>

                <MudStack Row="true">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Save" Disabled="@_saving">
                        @(_saving ? L["Admin_AppDetail_Saving"] : (_isCreate ? L["Admin_AppDetail_CreateApp"] : L["Admin_AppDetail_SaveChanges"]))
                    </MudButton>
                    <MudButton Variant="Variant.Text" OnClick='() => Navigation.NavigateTo("/admin/applications")'>
                        @L["Admin_AppDetail_Cancel"]
                    </MudButton>
                </MudStack>
            </MudForm>
        </MudItem>

        @if (!_isCreate)
        {
            <MudItem xs="12" md="4">
                <!-- Access Control -->
                <MudPaper Elevation="2" Class="pa-4 mb-4">
                    <MudText Typo="Typo.h6" GutterBottom="true">@L["Admin_AppDetail_AccessControl"]</MudText>
                    @if (_model.IsPublic)
                    {
                        <MudAlert Severity="Severity.Info" Dense="true">
                            @L["Admin_AppDetail_PublicAlert"]
                        </MudAlert>
                    }
                    else
                    {
                        <!-- Group Access -->
                        <MudText Typo="Typo.subtitle2" Class="mt-3 mb-1">@L["Admin_AppDetail_GroupAccess"]</MudText>
                        @foreach (var entry in _accessEntries.Where(e => e.GroupId.HasValue))
                        {
                            var g = _groups.FirstOrDefault(x => x.Id == entry.GroupId);
                            <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-1">
                                <MudIcon Icon="@Icons.Material.Filled.Group" Size="Size.Small" />
                                <MudText Typo="Typo.body2" Class="flex-1">@(g?.Name ?? L["Admin_AppDetail_UnknownGroup"])</MudText>
                                <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small"
                                               OnClick="() => RemoveAccess(entry.Id)" />
                            </MudStack>
                        }
                        <MudStack Row="true" Class="mt-2">
                            <MudSelect @bind-Value="_addGroupId" Label="@L["Admin_AppDetail_AddGroup"]" Variant="Variant.Outlined"
                                       Margin="Margin.Dense" Class="flex-1">
                                @foreach (var g in _groups.Where(g => !_accessEntries.Any(e => e.GroupId == g.Id)))
                                {
                                    <MudSelectItem Value="@((int?)g.Id)">@g.Name</MudSelectItem>
                                }
                            </MudSelect>
                            <MudIconButton Icon="@Icons.Material.Filled.Add" Color="Color.Primary"
                                           Disabled="@(_addGroupId is null)"
                                           OnClick="AddGroupAccess" />
                        </MudStack>

                        <!-- User Access -->
                        <MudDivider Class="my-3" />
                        <MudText Typo="Typo.subtitle2" Class="mb-1">@L["Admin_AppDetail_UserAccess"]</MudText>
                        @foreach (var entry in _accessEntries.Where(e => e.UserId is not null))
                        {
                            var u = _users.FirstOrDefault(x => x.Id == entry.UserId);
                            <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-1">
                                <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Small" />
                                <MudText Typo="Typo.body2" Class="flex-1">@(u?.DisplayName ?? u?.UserName ?? L["Admin_AppDetail_UnknownUser"])</MudText>
                                <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small"
                                               OnClick="() => RemoveAccess(entry.Id)" />
                            </MudStack>
                        }
                        <MudStack Row="true" Class="mt-2">
                            <MudSelect @bind-Value="_addUserId" Label="@L["Admin_AppDetail_AddUser"]" Variant="Variant.Outlined"
                                       Margin="Margin.Dense" Class="flex-1">
                                @foreach (var u in _users.Where(u => !_accessEntries.Any(e => e.UserId == u.Id)))
                                {
                                    <MudSelectItem Value="@u.Id">@(u.DisplayName ?? u.UserName)</MudSelectItem>
                                }
                            </MudSelect>
                            <MudIconButton Icon="@Icons.Material.Filled.Add" Color="Color.Primary"
                                           Disabled="@string.IsNullOrEmpty(_addUserId)"
                                           OnClick="AddUserAccess" />
                        </MudStack>
                    }
                </MudPaper>
            </MudItem>
        }
    </MudGrid>
}

@code {
    [Parameter] public int? Id { get; set; }

    private bool _isCreate;
    private bool _valid;
    private bool _saving;
    private bool _loading = true;
    private MudForm _form = default!;
    private AppModel _model = new();
    private List<ClientInfo> _clients = [];
    private List<AppLauncherAccess> _accessEntries = [];
    private List<Group> _groups = [];
    private List<ApplicationUser> _users = [];
    private int? _addGroupId;
    private string? _addUserId;

    protected override async Task OnInitializedAsync()
    {
        _isCreate = Id is null;
        _clients = [.. await ClientService.GetAllAsync()];

        if (!_isCreate)
        {
            var app = await ApplicationService.GetByIdAsync(Id!.Value);
            if (app is null)
            {
                Navigation.NavigateTo("/admin/applications");
                return;
            }

            _model = new AppModel
            {
                Name = app.Name,
                Slug = app.Slug,
                Description = app.Description,
                IconUrl = app.IconUrl,
                LaunchUrl = app.LaunchUrl,
                LinkedClientId = app.LinkedClientId,
                IsEnabled = app.IsEnabled,
                IsPublic = app.IsPublic
            };

            _accessEntries = [.. await ApplicationService.GetAccessEntriesAsync(Id!.Value)];
            _groups = [.. await GroupService.GetAllAsync()];
            _users = [.. await UserService.GetAllAsync()];
        }

        _loading = false;
    }

    private async Task Save()
    {
        await _form.ValidateAsync();
        if (!_valid) return;

        _saving = true;
        try
        {
            if (_isCreate)
            {
                await ApplicationService.CreateAsync(
                    _model.Name, _model.Slug, _model.Description, _model.IconUrl,
                    _model.LaunchUrl, _model.LinkedClientId, _model.IsEnabled, _model.IsPublic);
                Snackbar.Add(L["Admin_AppDetail_Created"], Severity.Success);
                Navigation.NavigateTo("/admin/applications");
            }
            else
            {
                await ApplicationService.UpdateAsync(
                    Id!.Value, _model.Name, _model.Slug, _model.Description, _model.IconUrl,
                    _model.LaunchUrl, _model.LinkedClientId, _model.IsEnabled, _model.IsPublic);
                Snackbar.Add(L["Admin_AppDetail_Saved"], Severity.Success);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task AddGroupAccess()
    {
        if (_addGroupId is null) return;
        await ApplicationService.AddGroupAccessAsync(Id!.Value, _addGroupId.Value);
        _accessEntries = [.. await ApplicationService.GetAccessEntriesAsync(Id!.Value)];
        _addGroupId = null;
    }

    private async Task AddUserAccess()
    {
        if (string.IsNullOrEmpty(_addUserId)) return;
        await ApplicationService.AddUserAccessAsync(Id!.Value, _addUserId);
        _accessEntries = [.. await ApplicationService.GetAccessEntriesAsync(Id!.Value)];
        _addUserId = null;
    }

    private async Task RemoveAccess(int accessId)
    {
        await ApplicationService.RemoveAccessAsync(accessId);
        _accessEntries = [.. await ApplicationService.GetAccessEntriesAsync(Id!.Value)];
    }

    private sealed class AppModel
    {
        public string Name { get; set; } = string.Empty;
        public string Slug { get; set; } = string.Empty;
        public string? Description { get; set; }
        public string? IconUrl { get; set; }
        public string? LaunchUrl { get; set; }
        public string? LinkedClientId { get; set; }
        public bool IsEnabled { get; set; } = true;
        public bool IsPublic { get; set; } = true;
    }
}
