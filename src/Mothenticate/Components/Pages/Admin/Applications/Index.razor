@page "/admin/applications"
@attribute [Authorize(Policy = AuthDefaults.AppAdminUserPolicy)]
@inject IAppLauncherService ApplicationService
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@inject IStringLocalizer<SharedResource> L

<PageTitle>Applications — Mothenticate Admin</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4">
    <MudText Typo="Typo.h4">@L["Admin_Apps_Title"]</MudText>
    <MudSpacer />
    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
               OnClick='() => Navigation.NavigateTo("/admin/applications/create")'>
        @L["Admin_Apps_NewApp"]
    </MudButton>
</MudStack>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" />
}
else if (_apps.Count == 0)
{
    <MudAlert Severity="Severity.Info">@L["Admin_Apps_NoApps"]</MudAlert>
}
else
{
    <MudGrid>
        @foreach (var app in _apps)
        {
            <MudItem xs="12" sm="6" md="4">
                <MudCard Elevation="2">
                    <MudCardHeader>
                        <CardHeaderAvatar>
                            @if (!string.IsNullOrEmpty(app.IconUrl))
                            {
                                <MudAvatar>
                                    <MudImage Src="@app.IconUrl" Alt="@app.Name"></MudImage>
                                </MudAvatar>
                            }
                            else
                            {
                                <MudAvatar Color="Color.Primary">
                                    @(app.Name.Length > 0 ? app.Name[0].ToString().ToUpper() : "A")
                                </MudAvatar>
                            }
                        </CardHeaderAvatar>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">@app.Name</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">@app.Slug</MudText>
                        </CardHeaderContent>
                        <CardHeaderActions>
                            <MudStack Row="true" Spacing="1">
                                @if (!app.IsEnabled)
                                {
                                    <MudChip T="string" Color="Color.Default" Size="Size.Small">@L["Admin_Apps_Disabled"]</MudChip>
                                }
                                @if (app.IsPublic)
                                {
                                    <MudChip T="string" Color="Color.Info" Size="Size.Small">@L["Admin_Apps_Public"]</MudChip>
                                }
                                else
                                {
                                    <MudChip T="string" Color="Color.Warning" Size="Size.Small">@L["Admin_Apps_Restricted"]</MudChip>
                                }
                            </MudStack>
                        </CardHeaderActions>
                    </MudCardHeader>
                    @if (!string.IsNullOrEmpty(app.Description))
                    {
                        <MudCardContent>
                            <MudText Typo="Typo.body2" Color="Color.Secondary">@app.Description</MudText>
                        </MudCardContent>
                    }
                    <MudCardActions>
                        <MudButton Size="Size.Small" StartIcon="@Icons.Material.Filled.Edit"
                                   OnClick='() => Navigation.NavigateTo("/admin/applications/" + app.Id)'>
                            @L["Admin_Apps_Edit"]
                        </MudButton>
                        @if (!string.IsNullOrEmpty(app.LaunchUrl))
                        {
                            <MudButton Size="Size.Small" StartIcon="@Icons.Material.Filled.OpenInNew"
                                       Href="@app.LaunchUrl" Target="_blank">
                                @L["Admin_Apps_Launch"]
                            </MudButton>
                        }
                        <MudButton Size="Size.Small" Color="Color.Error"
                                   StartIcon="@Icons.Material.Filled.Delete"
                                   OnClick="() => ConfirmDelete(app)">
                            @L["Admin_Apps_Delete"]
                        </MudButton>
                    </MudCardActions>
                </MudCard>
            </MudItem>
        }
    </MudGrid>
}

@code {
    private List<AppLauncher> _apps = [];
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        _apps = [.. await ApplicationService.GetAllAsync()];
        _loading = false;
    }

    private async Task ConfirmDelete(AppLauncher app)
    {
        var confirmed = await DialogService.ConfirmDeleteAsync(
            L["Admin_Apps_DeleteTitle"],
            string.Format(L["Admin_Apps_DeleteConfirm"], app.Name));

        if (confirmed == true)
        {
            await ApplicationService.DeleteAsync(app.Id);
            _apps.RemoveAll(a => a.Id == app.Id);
            Snackbar.Add(string.Format(L["Admin_Apps_Deleted"], app.Name), Severity.Success);
        }
    }
}
