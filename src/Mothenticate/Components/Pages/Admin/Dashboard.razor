@page "/admin"
@attribute [Authorize(Policy = AuthDefaults.AppAdminUserPolicy)]
@inject IUserService UserService
@inject IAppLauncherService AppLauncherService
@inject IClientService ClientService

<PageTitle>Dashboard — Mothenticate Admin</PageTitle>

<MudText Typo="Typo.h4" GutterBottom="true">Dashboard</MudText>

<MudGrid Class="mb-6">
    <MudItem xs="12" sm="6" md="3">
        <MudPaper Elevation="2" Class="pa-4">
            <MudStack Row="true" AlignItems="AlignItems.Center">
                <MudIcon Icon="@Icons.Material.Filled.People" Color="Color.Primary" Size="Size.Large" />
                <MudStack Spacing="0">
                    <MudText Typo="Typo.h4">@_userCount</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Total Users</MudText>
                </MudStack>
            </MudStack>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" sm="6" md="3">
        <MudPaper Elevation="2" Class="pa-4">
            <MudStack Row="true" AlignItems="AlignItems.Center">
                <MudIcon Icon="@Icons.Material.Filled.VpnKey" Color="Color.Secondary" Size="Size.Large" />
                <MudStack Spacing="0">
                    <MudText Typo="Typo.h4">@_activeClientCount</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Clients</MudText>
                </MudStack>
            </MudStack>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" sm="6" md="3">
        <MudPaper Elevation="2" Class="pa-4">
            <MudStack Row="true" AlignItems="AlignItems.Center">
                <MudIcon Icon="@Icons.Material.Filled.Apps" Color="Color.Secondary" Size="Size.Large" />
                <MudStack Spacing="0">
                    <MudText Typo="Typo.h4">@_activeApplicationCount</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Applications</MudText>
                </MudStack>
            </MudStack>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" sm="6" md="3">
        <MudPaper Elevation="2" Class="pa-4">
            <MudStack Row="true" AlignItems="AlignItems.Center">
                <MudIcon Icon="@Icons.Material.Filled.PersonOff" Color="Color.Warning" Size="Size.Large" />
                <MudStack Spacing="0">
                    <MudText Typo="Typo.h4">@_inactiveUserCount</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Inactive Users</MudText>
                </MudStack>
            </MudStack>
        </MudPaper>
    </MudItem>
</MudGrid>

<MudGrid>
    <MudItem xs="12" md="6">
        <MudPaper Elevation="2" Class="pa-4">
            <MudText Typo="Typo.h6" GutterBottom="true">Quick Links</MudText>
            <MudList T="string">
                <MudListItem Icon="@Icons.Material.Filled.PersonAdd" Href="/admin/users/create">Create User</MudListItem>
                <MudListItem Icon="@Icons.Material.Filled.AddCircle" Href="/admin/applications/create">Create Application</MudListItem>
                <MudListItem Icon="@Icons.Material.Filled.GroupAdd" Href="/admin/groups/create">Create Group</MudListItem>
                <MudListItem Icon="@Icons.Material.Filled.Settings" Href="/admin/settings">Application Settings</MudListItem>
            </MudList>
        </MudPaper>
    </MudItem>
</MudGrid>

@code {
    private int _userCount;
    private int _activeClientCount;
    private int _activeApplicationCount;
    private int _inactiveUserCount;

    protected override async Task OnInitializedAsync()
    {
        var users = await UserService.GetAllAsync();
        _userCount = users.Count;
        _inactiveUserCount = users.Count(u => !u.IsActive);

        var applications = await AppLauncherService.GetAllAsync();
        _activeApplicationCount = applications.Count(a => a.IsEnabled);

        var clients = await ClientService.GetAllAsync();
        _activeClientCount = clients.Count(c => c.IsEnabled);
    }
}
