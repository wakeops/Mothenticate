@page "/admin/users/create"
@page "/admin/users/{Id}"
@attribute [Authorize(Policy = AuthDefaults.AppAdminUserPolicy)]
@inject IUserService UserService
@inject IUserAttributeService UserAttributeService
@inject IGroupService GroupService
@inject IRoleService RoleService
@inject ISessionService SessionService
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@inject IStringLocalizer<SharedResource> L
@using Microsoft.AspNetCore.Identity

<PageTitle>@(_isCreate ? L["Admin_UserDetail_NewUser"] : _user?.UserName ?? L["Admin_UserDetail_NewUser"]) — Mothenticate Admin</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4">
    <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" OnClick='() => Navigation.NavigateTo("/admin/users")' />
    <MudText Typo="Typo.h4">@(_isCreate ? L["Admin_UserDetail_NewUser"] : _user?.UserName ?? L["Admin_UserDetail_NewUser"])</MudText>
</MudStack>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" />
}
else if (_isCreate)
{
    <MudPaper Elevation="2" Class="pa-4" Style="max-width:600px">
        <MudText Typo="Typo.h6" GutterBottom="true">@L["Admin_UserDetail_CreateUser"]</MudText>
        <MudForm @ref="_form" @bind-IsValid="_valid">
            <MudGrid>
                <MudItem xs="12">
                    <MudTextField @bind-Value="_create.Username" Label="@L["Admin_UserDetail_Username"]" Required="true"
                                  RequiredError="Username is required." Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12">
                    <MudTextField @bind-Value="_create.Email" Label="@L["Admin_UserDetail_Email"]" InputType="InputType.Email"
                                  Required="true" RequiredError="Email is required." Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12">
                    <MudTextField @bind-Value="_create.Password" Label="@L["Admin_UserDetail_Password"]" InputType="InputType.Password"
                                  Required="true" RequiredError="Password is required." Variant="Variant.Outlined" />
                </MudItem>
                @foreach (var userAttr in CreateFormAttributes)
                {
                    <MudItem xs="12">
                        <UserAttributeEditor Attribute="userAttr" Values="GetValuesList(userAttr.Id)"
                                              ReadOnly="@(!userAttr.CanEditAdmin)" />
                    </MudItem>
                }
            </MudGrid>
            <MudStack Row="true" Class="mt-4">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="CreateUser" Disabled="@_saving">
                    @(_saving ? L["Admin_UserDetail_Creating"] : L["Admin_UserDetail_CreateUser"])
                </MudButton>
                <MudButton Variant="Variant.Text" OnClick='() => Navigation.NavigateTo("/admin/users")'>
                    @L["Admin_UserDetail_Cancel"]
                </MudButton>
            </MudStack>
        </MudForm>
    </MudPaper>
}
else if (_user is not null)
{
    <MudTabs Elevation="2" Rounded="true" ApplyEffectsToContainer="true">

        <!-- Profile Tab -->
        <MudTabPanel Text="@L["Admin_UserDetail_Tab_Profile"]" Icon="@Icons.Material.Filled.Person">
            <MudPaper Elevation="0" Class="pa-4">
                <MudGrid Style="max-width:600px">
                    @foreach (var userAttr in _editableAttributes)
                    {
                        <MudItem xs="12">
                            <UserAttributeEditor Attribute="userAttr" Values="GetValuesList(userAttr.Id)"
                                                  ReadOnly="@(!userAttr.CanEditAdmin)" />
                        </MudItem>
                    }
                    <MudItem xs="12">
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveProfile" Disabled="@_saving">
                            @(_saving ? L["Admin_UserDetail_Saving"] : L["Admin_UserDetail_SaveProfile"])
                        </MudButton>
                    </MudItem>
                </MudGrid>
            </MudPaper>
        </MudTabPanel>

        <!-- Security Tab -->
        <MudTabPanel Text="@L["Admin_UserDetail_Tab_Security"]" Icon="@Icons.Material.Filled.Security">
            <MudPaper Elevation="0" Class="pa-4">
                <MudGrid>
                    <MudItem xs="12" md="6">
                        <MudText Typo="Typo.h6" GutterBottom="true">@L["Admin_UserDetail_AccountStatus"]</MudText>
                        <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-2">
                            <MudText>@L["Admin_UserDetail_Active"]</MudText>
                            <MudSwitch Value="@_user.IsActive" Color="Color.Primary"
                                       ValueChanged="@((bool v) => SetActive(v))" />
                        </MudStack>
                        @{
                            var isLocked = _user.LockoutEnd.HasValue && _user.LockoutEnd > DateTimeOffset.UtcNow;
                        }
                        <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4">
                            <MudText Color="@(isLocked ? Color.Error : Color.Default)">
                                @(isLocked ? string.Format(L["Admin_UserDetail_LockedUntil"], _user.LockoutEnd?.ToString("yyyy-MM-dd HH:mm")) : L["Admin_UserDetail_NotLocked"])
                            </MudText>
                            @if (isLocked)
                            {
                                <MudButton Variant="Variant.Outlined" Color="Color.Warning" Size="Size.Small"
                                           OnClick="Unlock">@L["Admin_UserDetail_Unlock"]</MudButton>
                            }
                            else
                            {
                                <MudButton Variant="Variant.Outlined" Color="Color.Error" Size="Size.Small"
                                           OnClick="Lock">@L["Admin_UserDetail_LockAccount"]</MudButton>
                            }
                        </MudStack>

                        <MudText Typo="Typo.h6" GutterBottom="true">@L["Admin_UserDetail_ResetPassword"]</MudText>
                        <MudTextField @bind-Value="_newPassword" Label="@L["Admin_UserDetail_NewPassword"]" InputType="InputType.Password"
                                      Variant="Variant.Outlined" Class="mb-2" Style="max-width:360px" />
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="ResetPassword">
                            @L["Admin_UserDetail_SetPassword"]
                        </MudButton>
                    </MudItem>
                </MudGrid>
            </MudPaper>
        </MudTabPanel>

        <!-- Sessions Tab -->
        <MudTabPanel Text="@L["Admin_UserDetail_Tab_Sessions"]" Icon="@Icons.Material.Filled.Devices">
            <MudPaper Elevation="0" Class="pa-4">
                <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-3">
                    <MudText Typo="Typo.h6">@L["Admin_UserDetail_ActiveSessions"]</MudText>
                    <MudSpacer />
                    @if (_sessions.Count > 0)
                    {
                        <MudButton Variant="Variant.Outlined" Color="Color.Error" Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.Logout" OnClick="RevokeAllSessions">
                            @L["Admin_UserDetail_RevokeAll"]
                        </MudButton>
                    }
                </MudStack>
                @if (_sessions.Count == 0)
                {
                    <MudText Color="Color.Secondary">@L["Admin_UserDetail_NoSessions"]</MudText>
                }
                else
                {
                    @foreach (var session in _sessions)
                    {
                        <MudPaper Outlined="true" Class="pa-3 mb-2">
                            <MudStack Row="true" AlignItems="AlignItems.Center">
                                <MudIcon Icon="@Icons.Material.Filled.Computer" Color="Color.Secondary" />
                                <MudStack Spacing="0">
                                    <MudText Typo="Typo.body2">@(session.UserAgent ?? L["Admin_UserDetail_UnknownDevice"])</MudText>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                                        @session.IpAddress — Last active @session.LastActiveAt.ToString("yyyy-MM-dd HH:mm")
                                    </MudText>
                                </MudStack>
                                <MudSpacer />
                                <MudButton Size="Size.Small" Color="Color.Error"
                                           OnClick="() => RevokeSession(session.Id)">
                                    @L["Admin_UserDetail_Revoke"]
                                </MudButton>
                            </MudStack>
                        </MudPaper>
                    }
                }
            </MudPaper>
        </MudTabPanel>

        <!-- Access Tab -->
        <MudTabPanel Text="@L["Admin_UserDetail_Tab_Access"]" Icon="@Icons.Material.Filled.AdminPanelSettings">
            <MudPaper Elevation="0" Class="pa-4">
                <MudGrid>
                    <MudItem xs="12" md="6">
                        <MudText Typo="Typo.h6" GutterBottom="true">@L["Admin_UserDetail_Groups"]</MudText>
                        @foreach (var group in _userGroups)
                        {
                            <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-1">
                                <MudChip T="string" Icon="@Icons.Material.Filled.Group">@group.Name</MudChip>
                                <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small"
                                               Color="Color.Error" OnClick="() => RemoveFromGroup(group.Id)" />
                            </MudStack>
                        }
                        <MudSelect T="int?" Placeholder="@L["Admin_UserDetail_AddToGroup"]" ValueChanged="AddToGroup"
                                   Variant="Variant.Outlined" Margin="Margin.Dense" Class="mt-2">
                            @foreach (var group in _allGroups.Where(g => _userGroups.All(ug => ug.Id != g.Id)))
                            {
                                <MudSelectItem T="int?" Value="@((int?)group.Id)">@group.Name</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudText Typo="Typo.h6" GutterBottom="true">@L["Admin_UserDetail_EffectiveRoles"]</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-2">
                            @L["Admin_UserDetail_RolesInherited"]
                        </MudText>
                        @foreach (var role in _effectiveRoles)
                        {
                            <MudChip T="string" Icon="@Icons.Material.Filled.Shield" Class="ma-1">@role.Name</MudChip>
                        }
                        @if (!_effectiveRoles.Any())
                        {
                            <MudText Color="Color.Secondary">@L["Admin_UserDetail_NoRoles"]</MudText>
                        }
                    </MudItem>
                </MudGrid>
            </MudPaper>
        </MudTabPanel>
    </MudTabs>
}

@code {
    [Parameter] public string? Id { get; set; }

    private bool _isCreate;
    private bool _loading = true;
    private bool _saving;
    private bool _valid;
    private MudForm _form = default!;

    private static readonly string[] IdentifierAttributeNames = ["username", "email"];

    private ApplicationUser? _user;
    private CreateModel _create = new();
    private string _newPassword = string.Empty;

    private List<UserSession> _sessions = [];
    private List<Group> _userGroups = [];
    private List<Group> _allGroups = [];
    private List<AppRole> _effectiveRoles = [];

    private List<UserAttribute> _editableAttributes = [];
    private Dictionary<int, List<string?>> _attributeValues = [];

    protected override async Task OnInitializedAsync()
    {
        _isCreate = string.IsNullOrEmpty(Id) || Id == "create";

        var allAttributes = await UserAttributeService.GetAllDefinitionsAsync();
        _editableAttributes = allAttributes.Where(a => a.CanViewAdmin).ToList();

        if (!_isCreate)
        {
            _user = await UserService.GetByIdAsync(Id!);
            if (_user is null)
            {
                Navigation.NavigateTo("/admin/users");
                return;
            }

            var attributeValues = await UserAttributeService.GetUserValuesAsync(Id!);
            _attributeValues = attributeValues
                .GroupBy(v => v.UserAttributeId)
                .ToDictionary(g => g.Key, g => g.OrderBy(v => v.Ordinal).Select(v => v.Value).ToList());

            SeedIdentifierValue("username", _user.UserName);
            SeedIdentifierValue("email", _user.Email);

            _sessions = [.. await SessionService.GetActiveByUserIdAsync(Id!)];
            _userGroups = [.. await UserService.GetGroupsAsync(Id!)];
            _effectiveRoles = [.. await UserService.GetEffectiveRolesAsync(Id!)];
            _allGroups = [.. await GroupService.GetAllAsync()];
        }

        _loading = false;
    }

    private IEnumerable<UserAttribute> CreateFormAttributes => _editableAttributes.Where(a =>
        !a.Name.Equals("username", StringComparison.OrdinalIgnoreCase) &&
        !a.Name.Equals("email", StringComparison.OrdinalIgnoreCase));

    private static bool IsIdentifierAttribute(UserAttribute attribute)
        => IdentifierAttributeNames.Contains(attribute.Name, StringComparer.OrdinalIgnoreCase);

    private UserAttribute? FindAttribute(string name)
        => _editableAttributes.FirstOrDefault(a => a.Name.Equals(name, StringComparison.OrdinalIgnoreCase));

    private List<string?> GetValuesList(int attributeId)
    {
        if (!_attributeValues.TryGetValue(attributeId, out var list))
        {
            list = [];
            _attributeValues[attributeId] = list;
        }

        return list;
    }

    private void SeedIdentifierValue(string name, string? value)
    {
        var attribute = FindAttribute(name);
        if (attribute is not null)
        {
            _attributeValues[attribute.Id] = [value];
        }
    }

    private string? GetIdentifierValue(string name)
    {
        var attribute = FindAttribute(name);
        if (attribute is null)
        {
            return null;
        }

        var values = GetValuesList(attribute.Id);
        return values.Count > 0 ? values[0] : null;
    }

    private async Task CreateUser()
    {
        await _form.ValidateAsync();
        if (!_valid) return;

        _saving = true;
        try
        {
            var result = await UserService.CreateAsync(_create.Username, _create.Email, _create.Password);

            if (result.Succeeded)
            {
                var created = (await UserService.GetAllAsync())
                    .FirstOrDefault(u => u.UserName == _create.Username || u.Email == _create.Email);
                if (created is not null)
                {
                    foreach (var attribute in CreateFormAttributes)
                    {
                        await UserAttributeService.SetUserValuesAsync(created.Id, attribute.Id, GetValuesList(attribute.Id));
                    }
                }

                Snackbar.Add(L["Admin_UserDetail_Created"], Severity.Success);
                Navigation.NavigateTo("/admin/users");
            }
            else
            {
                Snackbar.Add(string.Join(", ", result.Errors.Select(e => e.Description)), Severity.Error);
            }
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task SaveProfile()
    {
        _saving = true;
        try
        {
            var userName = GetIdentifierValue("username") ?? _user!.UserName ?? string.Empty;
            var email = GetIdentifierValue("email") ?? _user!.Email ?? string.Empty;

            var result = await UserService.UpdateIdentifiersAsync(Id!, userName, email);
            if (!result.Succeeded)
            {
                Snackbar.Add(string.Join(", ", result.Errors.Select(e => e.Description)), Severity.Error);
                return;
            }

            foreach (var attribute in _editableAttributes)
            {
                if (IsIdentifierAttribute(attribute)) continue;
                await UserAttributeService.SetUserValuesAsync(Id!, attribute.Id, GetValuesList(attribute.Id));
            }

            Snackbar.Add(L["Admin_UserDetail_ProfileSaved"], Severity.Success);
            _user = await UserService.GetByIdAsync(Id!);
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task SetActive(bool isActive)
    {
        var result = await UserService.SetActiveAsync(Id!, isActive);
        if (result.Succeeded)
        {
            _user = await UserService.GetByIdAsync(Id!);
            Snackbar.Add(isActive ? L["Admin_UserDetail_Activated"] : L["Admin_UserDetail_Deactivated"], Severity.Success);
        }
        else
        {
            Snackbar.Add(string.Join(", ", result.Errors.Select(e => e.Description)), Severity.Error);
        }
    }

    private async Task Lock()
    {
        var result = await UserService.LockAsync(Id!);
        if (result.Succeeded)
        {
            _user = await UserService.GetByIdAsync(Id!);
            Snackbar.Add(L["Admin_UserDetail_Locked_Msg"], Severity.Success);
        }
    }

    private async Task Unlock()
    {
        var result = await UserService.UnlockAsync(Id!);
        if (result.Succeeded)
        {
            _user = await UserService.GetByIdAsync(Id!);
            Snackbar.Add(L["Admin_UserDetail_Unlocked_Msg"], Severity.Success);
        }
    }

    private async Task ResetPassword()
    {
        if (string.IsNullOrWhiteSpace(_newPassword)) return;
        var result = await UserService.SetPasswordAsync(Id!, _newPassword);
        if (result.Succeeded)
        {
            _newPassword = string.Empty;
            Snackbar.Add(L["Admin_UserDetail_PasswordUpdated"], Severity.Success);
        }
        else
        {
            Snackbar.Add(string.Join(", ", result.Errors.Select(e => e.Description)), Severity.Error);
        }
    }

    private async Task RevokeSession(Guid sessionId)
    {
        await SessionService.RevokeAsync(sessionId);
        _sessions = [.. await SessionService.GetActiveByUserIdAsync(Id!)];
        Snackbar.Add(L["Admin_UserDetail_SessionRevoked"], Severity.Success);
    }

    private async Task RevokeAllSessions()
    {
        await SessionService.RevokeAllForUserAsync(Id!);
        _sessions = [];
        Snackbar.Add(L["Admin_UserDetail_AllSessionsRevoked"], Severity.Success);
    }

    private async Task AddToGroup(int? groupId)
    {
        if (groupId is null) return;
        await GroupService.AddMemberAsync(groupId.Value, Id!);
        _userGroups = [.. await UserService.GetGroupsAsync(Id!)];
        _effectiveRoles = [.. await UserService.GetEffectiveRolesAsync(Id!)];
        Snackbar.Add(L["Admin_UserDetail_AddedToGroup"], Severity.Success);
    }

    private async Task RemoveFromGroup(int groupId)
    {
        await GroupService.RemoveMemberAsync(groupId, Id!);
        _userGroups = [.. await UserService.GetGroupsAsync(Id!)];
        _effectiveRoles = [.. await UserService.GetEffectiveRolesAsync(Id!)];
        Snackbar.Add(L["Admin_UserDetail_RemovedFromGroup"], Severity.Success);
    }

    private sealed class CreateModel
    {
        public string Username { get; set; } = string.Empty;
        public string Email { get; set; } = string.Empty;
        public string Password { get; set; } = string.Empty;
    }
}
