@page "/admin/client-scopes/{ScopeId:int}/mappers/edit"
@page "/admin/client-scopes/{ScopeId:int}/mappers/edit/{Id:int}"
@attribute [Authorize(Policy = AuthDefaults.AppAdminUserPolicy)]
@inject IClientScopeService ClientScopeService
@inject IUserAttributeService UserAttributeService
@inject IScopeMapperResolver ScopeMapperResolver
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@inject IStringLocalizer<SharedResource> L
@using System.ComponentModel.DataAnnotations
@using System.Reflection
@using Mothenticate.IdentityProvider.Services.ScopeMappers
@using Mothenticate.IdentityProvider.Services.ScopeMappers.Abstract
@using Mothenticate.Models.Admin

<PageTitle>@(_isCreate ? L["Admin_ClientScopes_AddMapper"] : L["Admin_ClientScopes_EditMapper"]) — Mothenticate Admin</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4">
    <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" OnClick='() => Navigation.NavigateTo($"/admin/client-scopes/edit/{ScopeId}")' />
    <MudText Typo="Typo.h4">@(_isCreate ? L["Admin_ClientScopes_AddMapper"] : L["Admin_ClientScopes_EditMapper"])</MudText>
</MudStack>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" />
}
else
{
    <MudPaper Elevation="2" Class="pa-4" Style="max-width:600px">
        <MudGrid>
            <MudItem xs="12">
                <MudTextField @bind-Value="_model.Name" Label="@L["Admin_ClientScopes_MapperName"]" Variant="Variant.Outlined" Required="true" />
            </MudItem>
            <MudItem xs="12">
                <MudSelect T="MapperType" Value="_model.MapperType" ValueChanged="OnMapperTypeChanged" Label="@L["Admin_ClientScopes_ColType"]" Variant="Variant.Outlined">
                    @foreach (var type in Enum.GetValues<MapperType>())
                    {
                        <MudSelectItem Value="@type">@type</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>

            @if (_configFields.Count == 0)
            {
                <MudItem xs="12">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">@L["Admin_ClientScopes_AcrHelper"]</MudText>
                </MudItem>
            }
            else
            {
                @foreach (var field in _configFields)
                {
                    <MudItem xs="12">
                        @if (field.IsUserAttributeReference)
                        {
                            <MudSelect T="int?" Value="@GetConfigInt(field.Name)" ValueChanged="@(v => SetConfigInt(field.Name, v))"
                                       Label="@field.Label" Variant="Variant.Outlined" Required="@field.Required">
                                @foreach (var userAttr in _attributes)
                                {
                                    <MudSelectItem T="int?" Value="@((int?)userAttr.Id)">@userAttr.Name</MudSelectItem>
                                }
                            </MudSelect>
                        }
                        else if (field.ClrType == typeof(bool))
                        {
                            <MudCheckBox T="bool" Value="@GetConfigBool(field.Name)" ValueChanged="@((bool v) => SetConfigBool(field.Name, v))"
                                         Label="@field.Label" Color="Color.Primary" />
                        }
                        else if (field.ClrType.IsEnum)
                        {
                            <MudSelect T="string" Value="@GetConfigValue(field.Name)" ValueChanged="@(v => SetConfigValue(field.Name, v))"
                                       Label="@field.Label" Variant="Variant.Outlined" Required="@field.Required">
                                @foreach (var name in Enum.GetNames(field.ClrType))
                                {
                                    <MudSelectItem T="string" Value="@name">@name</MudSelectItem>
                                }
                            </MudSelect>
                        }
                        else
                        {
                            <MudTextField T="string" Value="@GetConfigValue(field.Name)" ValueChanged="@((string? v) => SetConfigValue(field.Name, v))"
                                          Label="@field.Label" Variant="Variant.Outlined" Required="@field.Required"
                                          InputType="@(field.ClrType == typeof(int) ? MudBlazor.InputType.Number : MudBlazor.InputType.Text)" />
                        }
                    </MudItem>
                }
            }

            @if (_supportsIdToken)
            {
                <MudItem xs="12">
                    <MudCheckBox @bind-Value="_includeIdToken" Label="@L["Admin_ClientScopes_AddToIdToken"]" Color="Color.Primary" />
                </MudItem>
            }
            @if (_supportsAccessToken)
            {
                <MudItem xs="12">
                    <MudCheckBox @bind-Value="_includeAccessToken" Label="@L["Admin_ClientScopes_AddToAccessToken"]" Color="Color.Primary" />
                </MudItem>
            }
            @if (_supportsUserInfo)
            {
                <MudItem xs="12">
                    <MudCheckBox @bind-Value="_includeUserInfo" Label="@L["Admin_ClientScopes_AddToUserInfo"]" Color="Color.Primary" />
                </MudItem>
            }
            @if (_supportsIntrospection)
            {
                <MudItem xs="12">
                    <MudCheckBox @bind-Value="_includeIntrospectionToken" Label="@L["Admin_ClientScopes_AddToIntrospection"]" Color="Color.Primary" />
                </MudItem>
            }
        </MudGrid>
        <MudStack Row="true" Class="mt-4">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Save" Disabled="@_saving">
                @(_isCreate ? L["Admin_ClientScopes_Create"] : L["Admin_ClientScopes_Save"])
            </MudButton>
            <MudButton Variant="Variant.Text" OnClick='() => Navigation.NavigateTo($"/admin/client-scopes/edit/{ScopeId}")'>
                @L["Admin_ClientScopes_Cancel"]
            </MudButton>
        </MudStack>
    </MudPaper>
}

@code {
    [Parameter] public int ScopeId { get; set; }
    [Parameter] public int? Id { get; set; }

    private record ConfigFieldMeta(string Name, string Label, Type ClrType, bool Required, bool IsUserAttributeReference);

    private bool _isCreate;
    private bool _loading = true;
    private bool _saving;
    private ClientScopeMapperEditModel _model = new();
    private List<UserAttribute> _attributes = [];
    private Dictionary<string, string> _configValues = [];
    private List<ConfigFieldMeta> _configFields = [];
    private bool _supportsAccessToken;
    private bool _supportsIdToken;
    private bool _supportsIntrospection;
    private bool _supportsUserInfo;
    private bool _includeAccessToken = true;
    private bool _includeIdToken = true;
    private bool _includeIntrospectionToken = true;
    private bool _includeUserInfo = true;

    protected override async Task OnInitializedAsync()
    {
        _isCreate = Id is null;
        _attributes = [.. await UserAttributeService.GetAllDefinitionsAsync()];

        if (!_isCreate)
        {
            var scope = await ClientScopeService.GetByIdAsync(ScopeId);
            var mapper = scope?.Mappers.FirstOrDefault(m => m.Id == Id);
            if (mapper is null)
            {
                Navigation.NavigateTo($"/admin/client-scopes/edit/{ScopeId}");
                return;
            }

            _model = new ClientScopeMapperEditModel
            {
                Id = mapper.Id,
                ClientScopeId = mapper.ClientScopeId,
                Name = mapper.Name,
                MapperType = mapper.MapperType
            };
            _configValues = DeserializeConfig(mapper.Config);
        }

        RefreshMapperMetadata();
        _loading = false;
    }

    private void OnMapperTypeChanged(MapperType type)
    {
        _model.MapperType = type;
        _configValues = [];
        RefreshMapperMetadata();
    }

    private void RefreshMapperMetadata()
    {
        var mapper = ScopeMapperResolver.Resolve(_model.MapperType);

        _supportsAccessToken = mapper is IAccessTokenMapper;
        _supportsIdToken = mapper is IIdTokenMapper;
        _supportsIntrospection = mapper is IIntrospectionTokenMapper;
        _supportsUserInfo = mapper is IUserInfoMapper;

        _configFields = mapper is IConfigurableMapper configurable
            ? [.. configurable.SettingsType.GetProperties(BindingFlags.Public | BindingFlags.Instance).Select(BuildFieldMeta)]
            : [];

        _includeAccessToken = ParseFlag(_configValues, "IncludeAccessToken", true);
        _includeIdToken = ParseFlag(_configValues, "IncludeIdToken", true);
        _includeIntrospectionToken = ParseFlag(_configValues, "IncludeIntrospectionToken", true);
        _includeUserInfo = ParseFlag(_configValues, "IncludeUserInfo", true);
    }

    private static ConfigFieldMeta BuildFieldMeta(PropertyInfo property) => new(
        property.Name,
        property.GetCustomAttribute<DisplayAttribute>()?.Name ?? property.Name,
        Nullable.GetUnderlyingType(property.PropertyType) ?? property.PropertyType,
        property.GetCustomAttribute<RequiredAttribute>() is not null,
        property.GetCustomAttribute<UserAttributeReferenceAttribute>() is not null);

    private string? GetConfigValue(string key) => _configValues.GetValueOrDefault(key);

    private void SetConfigValue(string key, string? value) => _configValues[key] = value ?? string.Empty;

    private int? GetConfigInt(string key) => int.TryParse(GetConfigValue(key), out var value) ? value : null;

    private void SetConfigInt(string key, int? value) => SetConfigValue(key, value?.ToString());

    private bool GetConfigBool(string key) => bool.TryParse(GetConfigValue(key), out var value) && value;

    private void SetConfigBool(string key, bool value) => SetConfigValue(key, value.ToString());

    private static bool ParseFlag(Dictionary<string, string> config, string key, bool fallback)
        => config.TryGetValue(key, out var value) && bool.TryParse(value, out var parsed) ? parsed : fallback;

    private static Dictionary<string, string> DeserializeConfig(string json)
        => System.Text.Json.JsonSerializer.Deserialize<Dictionary<string, string>>(json) ?? [];

    private async Task Save()
    {
        if (string.IsNullOrWhiteSpace(_model.Name))
        {
            Snackbar.Add(L["Admin_ClientScopes_MapperNameAndAttributeRequired"], Severity.Warning);
            return;
        }

        foreach (var field in _configFields.Where(f => f.Required))
        {
            if (string.IsNullOrWhiteSpace(GetConfigValue(field.Name)))
            {
                Snackbar.Add(L["Admin_ClientScopes_MapperNameAndAttributeRequired"], Severity.Warning);
                return;
            }
        }

        _saving = true;
        try
        {
            if (_supportsAccessToken) SetConfigValue("IncludeAccessToken", _includeAccessToken.ToString());
            if (_supportsIdToken) SetConfigValue("IncludeIdToken", _includeIdToken.ToString());
            if (_supportsIntrospection) SetConfigValue("IncludeIntrospectionToken", _includeIntrospectionToken.ToString());
            if (_supportsUserInfo) SetConfigValue("IncludeUserInfo", _includeUserInfo.ToString());

            var mapper = new ClientScopeMapper
            {
                Id = _model.Id,
                ClientScopeId = ScopeId,
                Name = _model.Name,
                MapperType = _model.MapperType,
                Config = System.Text.Json.JsonSerializer.Serialize(_configValues)
            };

            if (_isCreate)
            {
                await ClientScopeService.AddMapperAsync(mapper);
                Snackbar.Add(L["Admin_ClientScopes_MapperCreated"], Severity.Success);
            }
            else
            {
                await ClientScopeService.UpdateMapperAsync(mapper);
                Snackbar.Add(L["Admin_ClientScopes_MapperUpdated"], Severity.Success);
            }

            Navigation.NavigateTo($"/admin/client-scopes/edit/{ScopeId}");
        }
        finally
        {
            _saving = false;
        }
    }
}
