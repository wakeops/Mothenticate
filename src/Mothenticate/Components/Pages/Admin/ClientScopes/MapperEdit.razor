@page "/admin/client-scopes/{ScopeId:int}/mappers/edit"
@page "/admin/client-scopes/{ScopeId:int}/mappers/edit/{Id:int}"
@attribute [Authorize(Policy = AuthDefaults.AppAdminUserPolicy)]
@inject IClientScopeService ClientScopeService
@inject IUserAttributeService UserAttributeService
@inject IScopeMapperResolver ScopeMapperResolver
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@inject IStringLocalizer<SharedResource> L
@using Mothenticate.IdentityProvider.Services.ScopeMappers
@using Mothenticate.IdentityProvider.Services.ScopeMappers.Abstract
@using Mothenticate.Models.Admin

<PageTitle>@(_isCreate ? L["Admin_ClientScopes_AddMapper"] : L["Admin_ClientScopes_EditMapper"]) — Mothenticate Admin</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4">
    <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" OnClick='() => Navigation.NavigateTo($"/admin/client-scopes/edit/{ScopeId}")' />
    <MudText Typo="Typo.h4">@(_isCreate ? L["Admin_ClientScopes_AddMapper"] : L["Admin_ClientScopes_EditMapper"])</MudText>
</MudStack>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" />
}
else
{
    <MudPaper Elevation="2" Class="pa-4" Style="max-width:600px">
        <MudGrid>
            <MudItem xs="12">
                <MudTextField @bind-Value="_model.Name" Label="@L["Admin_ClientScopes_MapperName"]" Variant="Variant.Outlined" Required="true" />
            </MudItem>
            <MudItem xs="12">
                <MudSelect T="MapperType" Value="_model.MapperType" ValueChanged="OnMapperTypeChanged" Label="@L["Admin_ClientScopes_ColType"]" Variant="Variant.Outlined">
                    @foreach (var type in Enum.GetValues<MapperType>())
                    {
                        <MudSelectItem Value="@type">@type</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>

            @if (_configFields.Count == 0)
            {
                <MudItem xs="12">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">@L["Admin_ClientScopes_AcrHelper"]</MudText>
                </MudItem>
            }
            else
            {
                <MapperConfigFieldsEditor Fields="_configFields" ConfigValues="_configValues" Attributes="_attributes" />
            }

            @if (_supportsIdToken)
            {
                <MudItem xs="12">
                    <MudCheckBox @bind-Value="_model.IncludeIdToken" Label="@L["Admin_ClientScopes_AddToIdToken"]" Color="Color.Primary" />
                </MudItem>
            }
            @if (_supportsAccessToken)
            {
                <MudItem xs="12">
                    <MudCheckBox @bind-Value="_model.IncludeAccessToken" Label="@L["Admin_ClientScopes_AddToAccessToken"]" Color="Color.Primary" />
                </MudItem>
            }
            @if (_supportsUserInfo)
            {
                <MudItem xs="12">
                    <MudCheckBox @bind-Value="_model.IncludeUserInfo" Label="@L["Admin_ClientScopes_AddToUserInfo"]" Color="Color.Primary" />
                </MudItem>
            }
            @if (_supportsIntrospection)
            {
                <MudItem xs="12">
                    <MudCheckBox @bind-Value="_model.IncludeIntrospectionToken" Label="@L["Admin_ClientScopes_AddToIntrospection"]" Color="Color.Primary" />
                </MudItem>
            }
        </MudGrid>
        <MudStack Row="true" Class="mt-4">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Save" Disabled="@_saving">
                @(_isCreate ? L["Admin_ClientScopes_Create"] : L["Admin_ClientScopes_Save"])
            </MudButton>
            <MudButton Variant="Variant.Text" OnClick='() => Navigation.NavigateTo($"/admin/client-scopes/edit/{ScopeId}")'>
                @L["Admin_ClientScopes_Cancel"]
            </MudButton>
        </MudStack>
    </MudPaper>
}

@code {
    [Parameter] public int ScopeId { get; set; }
    [Parameter] public int? Id { get; set; }

    private bool _isCreate;
    private bool _loading = true;
    private bool _saving;
    private ClientScopeMapperEditModel _model = new();
    private List<UserAttribute> _attributes = [];
    private Dictionary<string, string> _configValues = [];
    private List<MapperConfigFieldsEditor.ConfigFieldMeta> _configFields = [];
    private bool _supportsAccessToken;
    private bool _supportsIdToken;
    private bool _supportsIntrospection;
    private bool _supportsUserInfo;

    protected override async Task OnInitializedAsync()
    {
        _isCreate = Id is null;
        _attributes = [.. await UserAttributeService.GetAllDefinitionsAsync()];

        if (!_isCreate)
        {
            var scope = await ClientScopeService.GetByIdAsync(ScopeId);
            var mapper = scope?.Mappers.FirstOrDefault(m => m.Id == Id);
            if (mapper is null)
            {
                Navigation.NavigateTo($"/admin/client-scopes/edit/{ScopeId}");
                return;
            }

            _model = new ClientScopeMapperEditModel
            {
                Id = mapper.Id,
                ClientScopeId = mapper.ClientScopeId,
                Name = mapper.Name,
                MapperType = mapper.MapperType,
                IncludeAccessToken = mapper.IncludeAccessToken,
                IncludeIdToken = mapper.IncludeIdToken,
                IncludeIntrospectionToken = mapper.IncludeIntrospectionToken,
                IncludeUserInfo = mapper.IncludeUserInfo
            };
            _configValues = MapperConfigSerializer.Deserialize(mapper.Config);
        }

        RefreshMapperMetadata();
        _loading = false;
    }

    private void OnMapperTypeChanged(MapperType type)
    {
        _model.MapperType = type;
        _configValues = [];
        RefreshMapperMetadata();
    }

    private void RefreshMapperMetadata()
    {
        var mapper = ScopeMapperResolver.Resolve(_model.MapperType);

        _supportsAccessToken = mapper is IAccessTokenMapper;
        _supportsIdToken = mapper is IIdTokenMapper;
        _supportsIntrospection = mapper is IIntrospectionTokenMapper;
        _supportsUserInfo = mapper is IUserInfoMapper;

        _configFields = mapper is IConfigurableMapper configurable
            ? MapperConfigFieldsEditor.ConfigFieldMeta.BuildFrom(configurable.SettingsType)
            : [];
    }

    private async Task Save()
    {
        if (string.IsNullOrWhiteSpace(_model.Name))
        {
            Snackbar.Add(L["Admin_ClientScopes_MapperNameAndAttributeRequired"], Severity.Warning);
            return;
        }

        foreach (var field in _configFields.Where(f => f.Required))
        {
            if (string.IsNullOrWhiteSpace(_configValues.GetValueOrDefault(field.Name)))
            {
                Snackbar.Add(L["Admin_ClientScopes_MapperNameAndAttributeRequired"], Severity.Warning);
                return;
            }
        }

        _saving = true;
        try
        {
            var mapper = new ClientScopeMapper
            {
                Id = _model.Id,
                ClientScopeId = ScopeId,
                Name = _model.Name,
                MapperType = _model.MapperType,
                Config = MapperConfigSerializer.Serialize(_configValues),
                IncludeAccessToken = _model.IncludeAccessToken,
                IncludeIdToken = _model.IncludeIdToken,
                IncludeIntrospectionToken = _model.IncludeIntrospectionToken,
                IncludeUserInfo = _model.IncludeUserInfo
            };

            if (_isCreate)
            {
                await ClientScopeService.AddMapperAsync(mapper);
                Snackbar.Add(L["Admin_ClientScopes_MapperCreated"], Severity.Success);
            }
            else
            {
                await ClientScopeService.UpdateMapperAsync(mapper);
                Snackbar.Add(L["Admin_ClientScopes_MapperUpdated"], Severity.Success);
            }

            Navigation.NavigateTo($"/admin/client-scopes/edit/{ScopeId}");
        }
        finally
        {
            _saving = false;
        }
    }
}
