@page "/admin/settings"
@attribute [Authorize(Policy = AuthDefaults.AppAdminUserPolicy)]
@inject IAppSettingsService SettingsService
@inject IIdentityProviderService IdentityProviderService
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@inject IStringLocalizer<SharedResource> L

<PageTitle>Settings — Mothenticate Admin</PageTitle>

<MudText Typo="Typo.h4" GutterBottom="true">@L["Admin_Settings_Title"]</MudText>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" />
}
else
{
    <MudTabs Elevation="2" Rounded="true" ApplyEffectsToContainer="true" TabPanelsClass="pa-6"
             ActivePanelIndex="@_activeTab">

        <!-- General -->
        <MudTabPanel Text="@L["Admin_Settings_TabGeneral"]">
            <MudGrid>
                <MudItem xs="12" md="6">
                    <MudPaper Elevation="2" Class="pa-4 mb-4">
                        <MudText Typo="Typo.h6" GutterBottom="true">@L["Admin_Settings_Branding"]</MudText>
                        <MudTextField @bind-Value="_settings.BrandingTitle" Label="@L["Admin_Settings_BrandingTitle"]"
                                      Variant="Variant.Outlined" Class="mb-3"
                                      HelperText="@L["Admin_Settings_BrandingTitle_Helper"]" />
                        <MudTextField @bind-Value="_settings.BrandingSubtitle" Label="@L["Admin_Settings_BrandingSubtitle"]"
                                      Variant="Variant.Outlined" Lines="2"
                                      HelperText="@L["Admin_Settings_BrandingSubtitle_Helper"]" />
                    </MudPaper>
                </MudItem>

                <MudItem xs="12" md="6">
                    <MudPaper Elevation="2" Class="pa-4 mb-4">
                        <MudText Typo="Typo.h6" GutterBottom="true">@L["Admin_Settings_UserMgmt"]</MudText>

                        <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-3">
                            <MudStack Spacing="0">
                                <MudText Typo="Typo.subtitle2">@L["Admin_Settings_EnableRegistration"]</MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">@L["Admin_Settings_EnableRegistration_Desc"]</MudText>
                            </MudStack>
                            <MudSpacer />
                            <MudSwitch @bind-Value="_settings.RegistrationEnabled" Color="Color.Primary" />
                        </MudStack>

                        <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-3">
                            <MudStack Spacing="0">
                                <MudText Typo="Typo.subtitle2">@L["Admin_Settings_UseEmailAsUsername"]</MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">@L["Admin_Settings_UseEmailAsUsername_Desc"]</MudText>
                            </MudStack>
                            <MudSpacer />
                            <MudSwitch @bind-Value="_settings.UseEmailAsUsername" Color="Color.Primary" />
                        </MudStack>

                        <MudStack Row="true" AlignItems="AlignItems.Center">
                            <MudStack Spacing="0">
                                <MudText Typo="Typo.subtitle2">@L["Admin_Settings_AllowEmailLogin"]</MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">@L["Admin_Settings_AllowEmailLogin_Desc"]</MudText>
                            </MudStack>
                            <MudSpacer />
                            <MudSwitch @bind-Value="_settings.AllowEmailLogin" Color="Color.Primary"
                                       Disabled="@_settings.UseEmailAsUsername" />
                        </MudStack>
                    </MudPaper>
                </MudItem>

                <MudItem xs="12">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Save" Disabled="@_saving">
                        @(_saving ? L["Admin_Settings_Saving"] : L["Admin_Settings_Save"])
                    </MudButton>
                </MudItem>
            </MudGrid>
        </MudTabPanel>

        <!-- Localization -->
        <MudTabPanel Text="@L["Admin_Settings_TabLocalization"]">
            <MudGrid>
                <MudItem xs="12" md="6">
                    <MudPaper Elevation="2" Class="pa-4 mb-4">
                        <MudText Typo="Typo.h6" GutterBottom="true">@L["Admin_Settings_Localization"]</MudText>
                        <MudSelect @bind-Value="_settings.DefaultLanguage" Label="@L["Admin_Settings_DefaultLanguage"]"
                                   Variant="Variant.Outlined"
                                   HelperText="@L["Admin_Settings_DefaultLanguage_Helper"]">
                            @foreach (var lang in LocalizationDefaults.SupportedLanguages)
                            {
                                <MudSelectItem Value="@lang.Code">@lang.DisplayName</MudSelectItem>
                            }
                        </MudSelect>
                    </MudPaper>
                </MudItem>

                <MudItem xs="12">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Save" Disabled="@_saving">
                        @(_saving ? L["Admin_Settings_Saving"] : L["Admin_Settings_Save"])
                    </MudButton>
                </MudItem>
            </MudGrid>
        </MudTabPanel>

        <!-- User Profile -->
        <MudTabPanel Text="@L["Admin_Settings_TabUserProfile"]">
            <MudGrid>
                <MudItem xs="12" md="8">
                    <!-- User attributes -->
                    <MudPaper Elevation="2" Class="pa-4">
                        <MudStack Row="true" AlignItems="AlignItems.Center">
                            <MudStack Spacing="0">
                                <MudText Typo="Typo.h6">@L["Admin_UserProps_CustomProps"]</MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">@L["Admin_UserProps_BuiltIn_Desc"]</MudText>
                            </MudStack>
                            <MudSpacer />
                            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                                       StartIcon="@Icons.Material.Filled.ManageAccounts"
                                       OnClick='() => Navigation.NavigateTo("/admin/user-attributes")'>
                                @L["Admin_UserProps_ManageAttributes"]
                            </MudButton>
                        </MudStack>
                    </MudPaper>
                </MudItem>

                <MudItem xs="12">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Save" Disabled="@_saving">
                        @(_saving ? L["Admin_Settings_Saving"] : L["Admin_Settings_Save"])
                    </MudButton>
                </MudItem>
            </MudGrid>
        </MudTabPanel>

        <!-- Identity Providers -->
        <MudTabPanel Text="@L["Admin_Settings_TabIdentityProviders"]">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-4">
                <MudTextField @bind-Value="_idpSearch" Placeholder="@L["Admin_IdP_Search"]"
                              Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                              Variant="Variant.Outlined" Clearable="true" Immediate="true"
                              Class="flex-1" />
                <MudMenu StartIcon="@Icons.Material.Filled.Add" Label="@L["Admin_IdP_NewProvider"]"
                         Variant="Variant.Filled" Color="Color.Primary" EndIcon="@Icons.Material.Filled.ArrowDropDown">
                    @foreach (var type in _idpCatalog.OrderBy(t => t.Id))
                    {
                        <MudMenuItem OnClick="@(() => Navigation.NavigateTo("/admin/identity-providers/create/" + type.Id))">
                            @type.Name
                        </MudMenuItem>
                    }
                </MudMenu>
            </MudStack>

            @{
                var filteredIdps = string.IsNullOrWhiteSpace(_idpSearch)
                    ? _idpConfigurations
                    : _idpConfigurations.Where(p =>
                        p.Alias.Contains(_idpSearch, StringComparison.OrdinalIgnoreCase) ||
                        p.ProviderType.Name.Contains(_idpSearch, StringComparison.OrdinalIgnoreCase)).ToList();
            }

            @if (_idpConfigurations.Count == 0)
            {
                <MudAlert Severity="Severity.Info">@L["Admin_IdP_None"]</MudAlert>
            }
            else
            {
                <MudTable Items="@filteredIdps" Hover="true" Dense="true">
                    <HeaderContent>
                        <MudTh Style="width:48px"></MudTh>
                        <MudTh>@L["Admin_IdP_ColName"]</MudTh>
                        <MudTh>@L["Admin_IdP_ColProvider"]</MudTh>
                        <MudTh Style="width:56px"></MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd>
                            @if (context.IsEnabled)
                            {
                                <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Small" />
                            }
                            else
                            {
                                <MudIcon Icon="@Icons.Material.Filled.Cancel" Color="Color.Error" Size="Size.Small" />
                            }
                        </MudTd>
                        <MudTd>
                            <MudLink Href="@("/admin/identity-providers/" + context.Id)">@context.Alias</MudLink>
                        </MudTd>
                        <MudTd>@context.ProviderType.Name</MudTd>
                        <MudTd>
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                           Color="Color.Error" OnClick="() => DeleteIdpProvider(context)" />
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            }
        </MudTabPanel>

    </MudTabs>
}

@code {
    private AppSettings _settings = new();
    private bool _loading = true;
    private bool _saving;
    private int _activeTab;

    private List<IdentityProviderType> _idpCatalog = [];
    private List<IdentityProvider> _idpConfigurations = [];
    private string _idpSearch = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
        var query = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query);
        if (query.TryGetValue("tab", out var tab) && tab == "idp")
            _activeTab = 3;

        (_settings, _idpCatalog, _idpConfigurations) = (
            await SettingsService.GetAsync(),
            [.. await IdentityProviderService.GetProviderTypesAsync()],
            [.. await IdentityProviderService.GetProvidersAsync()]
        );
        _loading = false;
    }

    private async Task Save()
    {
        _saving = true;
        try
        {
            await SettingsService.UpdateAsync(_settings);
            Snackbar.Add(L["Admin_Settings_Saved"], Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task DeleteIdpProvider(IdentityProvider provider)
    {
        var confirmed = await DialogService.ConfirmDeleteAsync(
            L["Admin_IdP_DeleteTitle"],
            string.Format(L["Admin_IdP_DeleteConfirm"], provider.Alias));

        if (confirmed == true)
        {
            await IdentityProviderService.DeleteProviderAsync(provider.Id);
            _idpConfigurations.RemoveAll(p => p.Id == provider.Id);
            Snackbar.Add(string.Format(L["Admin_IdP_Deleted"], provider.Alias), Severity.Success);
        }
    }

}
