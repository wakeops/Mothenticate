@inject IJSRuntime JS

<MudDialog>
    <TitleContent>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudIcon Icon="@Icons.Material.Filled.Key" Color="Color.Warning" />
            <MudText Typo="Typo.h6">Secret Generated</MudText>
        </MudStack>
    </TitleContent>
    <DialogContent>
        <MudAlert Severity="Severity.Warning" Class="mb-4" Dense="true">
            Copy this secret now — it will not be shown again.
        </MudAlert>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudTextField Value="@Secret" ReadOnly="true" Variant="Variant.Outlined"
                          FullWidth="true" Style="font-family: monospace;" />
            <MudTooltip Text="Copy to clipboard">
                <MudIconButton Icon="@Icons.Material.Filled.ContentCopy"
                               Color="Color.Default"
                               OnClick="CopyToClipboard" />
            </MudTooltip>
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Close">Done</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public string Secret { get; set; } = string.Empty;

    private async Task CopyToClipboard()
    {
        await JS.InvokeVoidAsync("navigator.clipboard.writeText", Secret);
    }

    private void Close() => MudDialog.Close();
}
